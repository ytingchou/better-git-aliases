#!/usr/bin/env bash
set -euo pipefail

BGA_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BGA_ROOT="$(cd "${BGA_BIN_DIR}/.." && pwd)"

has() {
  command -v "$1" >/dev/null 2>&1
}

can_use_fzf() {
  has fzf && [ -t 0 ] && [ -t 1 ]
}

config_home() {
  printf '%s/.config/better-git-aliases\n' "${HOME}"
}

user_config_file_path() {
  printf '%s/config.env\n' "$(config_home)"
}

repo_config_file_path() {
  local root
  root="$(repo_root 2>/dev/null || true)"
  [ -n "$root" ] || return 1
  printf '%s/.bga.env\n' "$root"
}

config_file_path() {
  user_config_file_path
}

config_value_from_file() {
  local file="$1" key="$2"
  [ -f "$file" ] || return 1
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, "", $0); print; found=1 } END { exit found ? 0 : 1 }' "$file"
}

ensure_config_home() {
  mkdir -p "$(config_home)"
}

config_get() {
  local key="$1"
  config_value_from_file "$(user_config_file_path)" "$key" && return 0
  config_value_from_file "$(repo_config_file_path)" "$key" && return 0
  return 1
}

config_set() {
  local key="$1" value="$2" tmp
  ensure_config_home
  tmp="$(mktemp)"
  if [ -f "$(user_config_file_path)" ]; then
    awk -F= -v key="$key" '$1 != key { print }' "$(user_config_file_path)" >"$tmp"
  fi
  printf '%s=%s\n' "$key" "$value" >>"$tmp"
  mv "$tmp" "$(user_config_file_path)"
}

config_list() {
  local repo_file user_file found=0 line key value effective
  repo_file="$(repo_config_file_path || true)"
  user_file="$(user_config_file_path)"
  if [ -n "$repo_file" ] && [ -f "$repo_file" ]; then
    printf 'repo defaults (%s):\n' "$repo_file"
    while IFS= read -r line; do
      [ -n "$line" ] || continue
      printf '  %s\n' "$line"
      found=1
    done < "$repo_file"
    printf '\n'
  fi
  if [ -f "$user_file" ]; then
    printf 'user overrides (%s):\n' "$user_file"
    while IFS= read -r line; do
      [ -n "$line" ] || continue
      printf '  %s\n' "$line"
      found=1
    done < "$user_file"
    printf '\n'
  fi
  printf 'effective values:\n'
  while IFS= read -r key; do
    [ -n "$key" ] || continue
    effective="$(config_get "$key" || true)"
    [ -n "$effective" ] || continue
    printf '  %s=%s\n' "$key" "$effective"
    found=1
  done <<'EOF'
base_branch
remote
cockpit_layout
workspace_root
protected_branches
EOF
  [ "$found" -eq 1 ] || printf '  (none)\n'
}

default_protected_branches() {
  printf 'main\ndevelop\nmaster\ndev\n'
}

configured_protected_branches() {
  local configured
  configured="$(config_get protected_branches || true)"
  if [ -n "$configured" ]; then
    printf '%s\n' "$configured" | tr ',' '\n' | sed 's/^ *//; s/ *$//' | awk 'NF'
  else
    default_protected_branches
  fi
}

protected_branches_regex() {
  local current="${1:-}"
  {
    configured_protected_branches
    [ -n "$current" ] && printf '%s\n' "$current"
  } | awk 'NF && !seen[$0]++' | paste -sd'|' -
}

asset_path() {
  local rel="$1"
  if [ -f "${BGA_ROOT}/${rel}" ]; then
    printf '%s\n' "${BGA_ROOT}/${rel}"
    return 0
  fi
  if [ -f "$(config_home)/${rel}" ]; then
    printf '%s\n' "$(config_home)/${rel}"
    return 0
  fi
  return 1
}

shell_helper_path() {
  if [ -f "${BGA_ROOT}/shell/bga.sh" ]; then
    printf '%s\n' "${BGA_ROOT}/shell/bga.sh"
    return 0
  fi
  if [ -f "$(config_home)/shell/bga.sh" ]; then
    printf '%s\n' "$(config_home)/shell/bga.sh"
    return 0
  fi
  printf '%s\n' "${BGA_ROOT}/shell/bga.sh"
}

managed_lazygit_template_path() {
  if [ -f "${BGA_ROOT}/config/lazygit/config.yml" ]; then
    printf '%s\n' "${BGA_ROOT}/config/lazygit/config.yml"
    return 0
  fi
  asset_path "lazygit/template.yml"
}

managed_lazygit_config_path() {
  printf '%s/.config/lazygit/config.yml\n' "${HOME}"
}

backup_root() {
  printf '%s/.config/better-git-aliases/backups\n' "${HOME}"
}

timestamp() {
  date '+%Y%m%d-%H%M%S'
}

latest_version_tag() {
  git tag --list 'v*' --sort=-version:refname | head -n 1
}

path_has_dir() {
  local dir="$1" item old_ifs
  old_ifs="${IFS:- }"
  IFS=':'
  for item in $PATH; do
    [ "$item" = "$dir" ] && IFS="$old_ifs" && return 0
  done
  IFS="$old_ifs"
  return 1
}

shell_rc_path() {
  local shell_name
  shell_name="$(basename "${SHELL:-bash}")"
  case "$shell_name" in
    zsh) printf '%s/.zshrc\n' "$HOME" ;;
    bash|*) printf '%s/.bashrc\n' "$HOME" ;;
  esac
}

shell_rc_mentions_helper() {
  local rc helper
  rc="$(shell_rc_path)"
  helper="$(shell_helper_path)"
  [ -f "$rc" ] || return 1
  grep -Fq "$helper" "$rc"
}

die() {
  printf 'bga: %s\n' "$*" >&2
  exit 1
}

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null
}

repo_name() {
  basename "$(repo_root)"
}

sanitize_name() {
  printf '%s' "$1" | tr '/[:space:]' '--' | tr -cd '[:alnum:]._-' | sed 's/--*/-/g; s/^-//; s/-$//'
}

current_branch() {
  git branch --show-current 2>/dev/null || true
}

default_base_branch() {
  local configured
  configured="$(config_get base_branch || true)"
  if [ -n "$configured" ]; then
    printf '%s\n' "$configured"
    return 0
  fi
  if git show-ref --verify --quiet refs/heads/main; then
    printf 'main\n'
  elif git show-ref --verify --quiet refs/heads/master; then
    printf 'master\n'
  else
    git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##' || printf 'main\n'
  fi
}

workspace_root() {
  local configured root
  configured="$(config_get workspace_root || true)"
  if [ -n "$configured" ]; then
    printf '%s\n' "$configured"
    return 0
  fi
  root="$(repo_root 2>/dev/null || pwd)"
  printf '%s\n' "$(dirname "$root")"
}

worktree_root() {
  local root name parent
  root="$(repo_root)"
  name="$(basename "$root")"
  parent="$(dirname "$root")"
  printf '%s/.worktrees/%s\n' "$parent" "$name"
}

ensure_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repository"
}

require_clean_or_confirm() {
  if ! git diff --quiet || ! git diff --cached --quiet; then
    printf 'warning: working tree has uncommitted changes\n' >&2
  fi
}

fzf_or_first() {
  local prompt="${1:-select> }"
  if can_use_fzf; then
    fzf --height=80% --layout=reverse --border --prompt="$prompt"
  else
    head -n 1
  fi
}

list_branches() {
  git for-each-ref \
    --sort=-committerdate \
    --format='%(refname:short)|%(committerdate:relative)|%(authorname)|%(subject)' \
    refs/heads refs/remotes
}

branch_picker() {
  if has fzf; then
    list_branches | fzf \
      --delimiter='|' \
      --with-nth=1,2,3,4 \
      --preview-window='right,65%,border-left' \
      --height=85% \
      --layout=reverse \
      --border \
      --prompt='branch> ' \
      --header='branch | updated | author | subject' \
      --preview '
        branch=$(printf "%s" {} | cut -d"|" -f1)
        branch=${branch#origin/}
        git log --color=always --decorate --stat -n 12 "$branch"
      ' \
      | cut -d'|' -f1
  else
    list_branches | column -t -s '|' | fzf_or_first "branch> " | awk '{print $1}'
  fi
}

list_worktrees() {
  git worktree list --porcelain | awk '
    /^worktree / { path=$2 }
    /^branch / { branch=$2; sub("refs/heads/", "", branch) }
    /^HEAD / && branch == "" { branch="detached" }
    /^$/ {
      if (path != "") print path "|" branch
      path=""
      branch=""
    }'
}

current_worktree_path() {
  git rev-parse --path-format=absolute --show-toplevel 2>/dev/null
}

branch_worktrees() {
  local branch="$1"
  list_worktrees | awk -F'|' -v branch="$branch" '$2 == branch { print $1 "|" $2 }'
}

branch_is_merged_into() {
  local branch="$1" base="$2"
  git show-ref --verify --quiet "refs/heads/${branch}" || return 1
  git show-ref --verify --quiet "refs/heads/${base}" || return 1
  git merge-base --is-ancestor "refs/heads/${branch}" "refs/heads/${base}"
}

managed_worktree_path() {
  local path="$1"
  case "$path" in
    "$(worktree_root)"/*) return 0 ;;
    *) return 1 ;;
  esac
}

repo_is_dirty() {
  local path="$1"
  (
    cd "$path" || exit 1
    ! git diff --quiet || ! git diff --cached --quiet
  )
}

workspace_repo_roots() {
  local root="${1:-$(workspace_root)}" current="" explicit_root=0
  [ -d "$root" ] || die "workspace root does not exist: $root"
  [ $# -gt 0 ] && explicit_root=1
  current="$(repo_root 2>/dev/null || true)"
  {
    if [ -n "$current" ]; then
      case "$current" in
        "$root"/*|"$root") printf '%s\n' "$current" ;;
        *)
          [ "$explicit_root" -eq 0 ] && printf '%s\n' "$current"
          ;;
      esac
    fi
    find "$root" -mindepth 1 -maxdepth 4 \( -type d -name .git -o -type f -name .git \) -print 2>/dev/null \
      | while IFS= read -r gitpath; do
          case "$gitpath" in
            */.worktrees/*) continue ;;
          esac
          dirname "$gitpath"
        done
  } | awk 'NF && !seen[$0]++'
}

workspace_repo_branch() {
  local path="$1"
  (cd "$path" && current_branch)
}

workspace_repo_upstream_summary() {
  local path="$1" branch counts parsed ahead behind
  branch="$(workspace_repo_branch "$path")"
  [ -n "$branch" ] || {
    printf 'detached\n'
    return 0
  }
  counts="$(cd "$path" && branch_ahead_behind "$branch" || true)"
  if [ -n "$counts" ]; then
    parsed="$(parse_ahead_behind "$counts")"
    ahead="${parsed%% *}"
    behind="${parsed##* }"
    printf 'ahead %s / behind %s\n' "${ahead:-0}" "${behind:-0}"
  else
    printf 'no upstream\n'
  fi
}

workspace_repo_worktree_count() {
  local path="$1"
  (cd "$path" && list_worktrees | awk 'NF { c++ } END { print c + 0 }')
}

workspace_repo_last_commit_epoch() {
  local path="$1"
  (cd "$path" && git log -1 --format='%ct' 2>/dev/null || printf '0\n')
}

workspace_repo_status_fields() {
  local repo="$1" branch dirty upstream worktrees counts parsed ahead behind priority last_commit
  branch="$(workspace_repo_branch "$repo")"
  dirty='clean'
  if repo_is_dirty "$repo"; then
    dirty='dirty'
  fi
  upstream="$(workspace_repo_upstream_summary "$repo")"
  worktrees="$(workspace_repo_worktree_count "$repo")"
  last_commit="$(workspace_repo_last_commit_epoch "$repo")"
  priority=0
  case "$dirty" in
    dirty) priority=$((priority + 30)) ;;
  esac
  case "$upstream" in
    no\ upstream) priority=$((priority + 20)) ;;
    ahead*)
      counts="${upstream#ahead }"
      parsed="$(printf '%s' "$counts" | sed 's# / behind # #')"
      ahead="${parsed%% *}"
      behind="${parsed##* }"
      if [ "${ahead:-0}" -gt 0 ] || [ "${behind:-0}" -gt 0 ]; then
        priority=$((priority + 10))
      fi
      ;;
  esac
  printf '%s|%s|%s|%s|%s|%s|%s\n' "$repo" "${branch:-detached}" "$dirty" "$upstream" "$worktrees" "$priority" "$last_commit"
}

list_workspace_repos() {
  local root="${1:-$(workspace_root)}" repo
  while IFS= read -r repo; do
    [ -n "$repo" ] || continue
    workspace_repo_status_fields "$repo"
  done < <(workspace_repo_roots "$root")
}

sorted_workspace_repos() {
  local root="${1:-$(workspace_root)}"
  list_workspace_repos "$root" | sort -t'|' -k6,6nr -k7,7nr -k1,1
}

workspace_repo_picker() {
  local root="${1:-$(workspace_root)}"
  if can_use_fzf; then
    sorted_workspace_repos "$root" | fzf \
      --delimiter='|' \
      --with-nth=2,3,4,1 \
      --preview-window='right,65%,border-left' \
      --height=85% \
      --layout=reverse \
      --border \
      --prompt='repo> ' \
      --header='branch | status | upstream | path' \
      --preview '
        path=$(printf "%s" {} | cut -d"|" -f1)
        if [ -d "$path" ]; then
          cd "$path" || exit 1
          printf "Path: %s\n\n" "$path"
          git status -sb
          printf "\nRecent commits:\n"
          git log --oneline --decorate -n 8
          printf "\nWorktrees:\n"
          git worktree list
        fi
      ' \
      | cut -d'|' -f1
  else
    sorted_workspace_repos "$root" | column -t -s '|' | fzf_or_first "repo> " | awk '{print $1}'
  fi
}

branch_upstream() {
  local branch="$1"
  git rev-parse --abbrev-ref --symbolic-full-name "${branch}@{upstream}" 2>/dev/null || true
}

branch_ahead_behind() {
  local branch="$1" upstream
  upstream="$(branch_upstream "$branch")"
  [ -n "$upstream" ] || return 1
  git rev-list --left-right --count "${branch}...${upstream}" 2>/dev/null
}

parse_ahead_behind() {
  local counts="$1"
  local ahead behind
  IFS=$'\t' read -r ahead behind <<EOF
$counts
EOF
  printf '%s %s\n' "${ahead:-0}" "${behind:-0}"
}

print_dashboard_attention() {
  local current_path branch path found=0 counts parsed ahead behind
  current_path="$(current_worktree_path)"
  printf 'attention:\n'

  if repo_is_dirty "$current_path"; then
    printf '  - current worktree has uncommitted changes\n'
    found=1
  fi

  branch="$(current_branch)"
  if [ -n "$branch" ]; then
    counts="$(branch_ahead_behind "$branch" || true)"
    if [ -n "$counts" ]; then
      parsed="$(parse_ahead_behind "$counts")"
      ahead="${parsed%% *}"
      behind="${parsed##* }"
      if [ "${ahead:-0}" -gt 0 ] || [ "${behind:-0}" -gt 0 ]; then
        printf '  - current branch %s is ahead %s / behind %s vs upstream\n' "$branch" "$ahead" "$behind"
        found=1
      fi
    else
      printf '  - current branch %s has no upstream\n' "$branch"
      found=1
    fi
  fi

  while IFS='|' read -r path branch; do
    [ -n "$path" ] || continue
    [ "$path" = "$current_path" ] && continue
    if repo_is_dirty "$path"; then
      printf '  - dirty worktree: %s (%s)\n' "$path" "$branch"
      found=1
    fi
  done < <(list_worktrees)

  while IFS='|' read -r path branch reason; do
    case "$path" in
      No\ stale\ managed\ worktrees\ found.) break ;;
    esac
    [ -n "$path" ] || continue
    printf '  - stale worktree: %s (%s)\n' "$path" "$branch"
    found=1
  done < <(cmd_worktree_stale "$(default_base_branch)")

  [ "$found" -eq 1 ] || printf '  - nothing urgent\n'
}

print_dashboard_worktrees() {
  local current_path path branch marker dirty
  current_path="$(current_worktree_path)"
  printf 'worktrees:\n'
  while IFS='|' read -r path branch; do
    [ -n "$path" ] || continue
    marker=' '
    [ "$path" = "$current_path" ] && marker='*'
    dirty='clean'
    if repo_is_dirty "$path"; then
      dirty='dirty'
    fi
    printf '  %s %s | %s | %s\n' "$marker" "$branch" "$dirty" "$path"
  done < <(list_worktrees)
}

print_dashboard_recent_branches() {
  local branch when author subject upstream counts parsed ahead behind line_count=0
  printf 'recent branches:\n'
  while IFS='|' read -r branch when author subject; do
    [ -n "$branch" ] || continue
    upstream="$(branch_upstream "${branch#origin/}")"
    if [ -n "$upstream" ]; then
      counts="$(branch_ahead_behind "${branch#origin/}" || true)"
      parsed="$(parse_ahead_behind "$counts")"
      ahead="${parsed%% *}"
      behind="${parsed##* }"
      printf '  %s | %s | ahead %s / behind %s | %s\n' "$branch" "$when" "${ahead:-0}" "${behind:-0}" "$subject"
    else
      printf '  %s | %s | no upstream | %s\n' "$branch" "$when" "$subject"
    fi
    line_count=$((line_count + 1))
    [ "$line_count" -ge 8 ] && break
  done < <(list_branches)
}

worktree_picker() {
  if has fzf; then
    list_worktrees | fzf \
      --delimiter='|' \
      --with-nth=2,1 \
      --preview-window='right,65%,border-left' \
      --height=85% \
      --layout=reverse \
      --border \
      --prompt='worktree> ' \
      --header='branch | path' \
      --preview '
        path=$(printf "%s" {} | cut -d"|" -f1)
        if [ -d "$path" ]; then
          cd "$path" || exit 1
          printf "Path: %s\n\n" "$path"
          git status -sb
          printf "\nRecent commits:\n"
          git log --oneline --decorate -n 10
          printf "\nFiles:\n"
          find . -maxdepth 2 -type f | sed "s#^\./##" | sort | head -n 40
        fi
      ' \
      | cut -d'|' -f1
  else
    list_worktrees | column -t -s '|' | fzf_or_first "worktree> " | awk '{print $1}'
  fi
}

open_lazygit() {
  local target="${1:-.}"
  has lazygit || die "lazygit is not installed"
  (cd "$target" && lazygit)
}

open_ai_cli() {
  local tool="$1"
  local target="${2:-.}"
  has "$tool" || die "$tool is not installed"
  (cd "$target" && "$tool")
}

open_url() {
  local url="$1"
  if has xdg-open; then
    xdg-open "$url" >/dev/null 2>&1 &
  elif has open; then
    open "$url" >/dev/null 2>&1 &
  else
    die "no supported URL opener found; print the URL and open it manually"
  fi
}

remote_url() {
  local remote="${1:-$(config_get remote || printf 'origin')}"
  git remote get-url "$remote" 2>/dev/null || die "git remote '$remote' not found"
}

provider_from_remote_host() {
  local host="$1"
  case "$host" in
    github.com) printf 'github\n' ;;
    gitlab.com) printf 'gitlab\n' ;;
    dev.azure.com|ssh.dev.azure.com|*.visualstudio.com|vs-ssh.visualstudio.com) printf 'azure-devops\n' ;;
    *) printf 'generic\n' ;;
  esac
}

remote_info_fields() {
  local remote="${1:-$(config_get remote || printf 'origin')}" url host path provider web_url
  url="$(remote_url "$remote")"
  case "$url" in
    git@*:* )
      host="${url#git@}"
      host="${host%%:*}"
      path="${url#*:}"
      ;;
    ssh://git@*/*)
      host="${url#ssh://git@}"
      host="${host%%/*}"
      path="${url#ssh://git@${host}/}"
      ;;
    https://*/*)
      host="${url#https://}"
      host="${host%%/*}"
      path="${url#https://${host}/}"
      ;;
    http://*/*)
      host="${url#http://}"
      host="${host%%/*}"
      path="${url#http://${host}/}"
      ;;
    *)
      die "unsupported remote URL format: $url"
      ;;
  esac

  path="${path%.git}"
  provider="$(provider_from_remote_host "$host")"
  case "$provider" in
    github|gitlab)
      web_url="https://${host}/${path}"
      ;;
    azure-devops)
      case "$host" in
        dev.azure.com)
          web_url="https://${host}/${path}"
          ;;
        ssh.dev.azure.com)
          path="${path#v3/}"
          web_url="https://dev.azure.com/${path%%/*}/${path#*/}"
          web_url="${web_url%/*}/_git/${web_url##*/}"
          ;;
        vs-ssh.visualstudio.com)
          path="${path#v3/}"
          web_url="https://${path%%/*}.visualstudio.com/${path#*/}"
          web_url="${web_url%/*}/_git/${web_url##*/}"
          ;;
        *.visualstudio.com)
          web_url="https://${host}/${path}"
          ;;
      esac
      ;;
    *)
      web_url="https://${host}/${path}"
      ;;
  esac

  printf '%s|%s|%s|%s|%s|%s\n' "$remote" "$provider" "$host" "$path" "$web_url" "$url"
}

compare_url() {
  local base="$1" compare="$2" remote="${3:-$(config_get remote || printf 'origin')}"
  local parsed provider web_url
  parsed="$(remote_info_fields "$remote")"
  provider="$(printf '%s' "$parsed" | cut -d'|' -f2)"
  web_url="$(printf '%s' "$parsed" | cut -d'|' -f5)"
  case "$provider" in
    github)
      printf '%s/compare/%s...%s\n' "$web_url" "$base" "$compare"
      ;;
    gitlab)
      printf '%s/-/compare/%s...%s\n' "$web_url" "$base" "$compare"
      ;;
    azure-devops|generic)
      printf '%s\n' "$web_url"
      ;;
  esac
}

github_https_remote_url() {
  local remote="${1:-$(config_get remote || printf 'origin')}" parsed provider web_url
  parsed="$(remote_info_fields "$remote")"
  provider="$(printf '%s' "$parsed" | cut -d'|' -f2)"
  web_url="$(printf '%s' "$parsed" | cut -d'|' -f5)"
  [ "$provider" = "github" ] || die "remote '$remote' is not a supported GitHub URL"
  printf '%s\n' "$web_url"
}

tmux_attach_or_switch() {
  local session="$1"
  if [ -n "${TMUX:-}" ]; then
    exec tmux switch-client -t "$session"
  fi
  exec tmux attach -t "$session"
}

preferred_ai_tool() {
  if has codex; then
    printf 'codex\n'
  elif has cline; then
    printf 'cline\n'
  else
    return 1
  fi
}

cockpit_layout_exists() {
  case "$1" in
    solo|review|ai-pair|multi-feature) return 0 ;;
    *) return 1 ;;
  esac
}

cockpit_session_name() {
  local target="$1" layout="$2"
  local repo target_name
  repo="$(sanitize_name "$(repo_name)")"
  target_name="$(sanitize_name "$(basename "$target")")"
  printf 'bga-%s-%s-%s\n' "$repo" "$target_name" "$layout"
}

create_tmux_window() {
  local session="$1" target="$2" name="$3" command="$4"
  tmux new-window -t "$session" -c "$target" -n "$name"
  [ -n "$command" ] && tmux send-keys -t "$session:$name" "$command" C-m
}

configure_tmux_layout() {
  local session="$1" target="$2" layout="$3"
  local ai_tool=""
  ai_tool="$(preferred_ai_tool || true)"

  case "$layout" in
    solo)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      if [ -n "$ai_tool" ]; then
        create_tmux_window "$session" "$target" "$ai_tool" "$ai_tool"
      fi
      ;;
    review)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      create_tmux_window "$session" "$target" log "git log --graph --decorate --oneline -n 40"
      create_tmux_window "$session" "$target" status "git status -sb && printf '\\nRecent branches:\\n' && git branch --sort=-committerdate | head -n 12"
      ;;
    ai-pair)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      if [ -n "$ai_tool" ]; then
        create_tmux_window "$session" "$target" "$ai_tool" "$ai_tool"
      fi
      create_tmux_window "$session" "$target" notes "printf 'Branch: '; git branch --show-current; printf '\\nNext actions:\\n- inspect diff\\n- ask AI for help\\n- apply and test changes\\n'"
      ;;
    multi-feature)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      create_tmux_window "$session" "$target" worktrees "git worktree list && printf '\\nRecent branches:\\n' && git branch --sort=-committerdate | head -n 20"
      create_tmux_window "$session" "$target" status "watch -n 5 'git status -sb; printf \"\\n\"; git branch --show-current'" 
      if [ -n "$ai_tool" ]; then
        create_tmux_window "$session" "$target" "$ai_tool" "$ai_tool"
      fi
      ;;
  esac
}

open_tmux_workspace() {
  local target="${1:-.}"
  local layout="${2:-solo}"
  local session
  has tmux || die "tmux is not installed"
  cockpit_layout_exists "$layout" || die "unknown cockpit layout: $layout"
  session="$(cockpit_session_name "$target" "$layout")"

  if tmux has-session -t "$session" 2>/dev/null; then
    tmux_attach_or_switch "$session"
  fi

  tmux new-session -d -s "$session" -c "$target" -n shell
  tmux send-keys -t "$session:shell" 'clear' C-m
  configure_tmux_layout "$session" "$target" "$layout"
  tmux select-window -t "$session:shell"
  tmux_attach_or_switch "$session"
}

