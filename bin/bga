}

cmd_doctor() {
  local missing=0
  printf 'better-git-aliases doctor\n\n'
  printf 'core:\n'
  for tool in git bash; do
    if has "$tool"; then
      printf '  [ok]   %s -> %s\n' "$tool" "$(command -v "$tool")"
    else
      printf '  [miss] %s\n' "$tool"
      missing=1
    fi
  done

  printf '\nrecommended:\n'
  for tool in fzf lazygit tmux delta codex cline; do
    if has "$tool"; then
      printf '  [ok]   %s -> %s\n' "$tool" "$(command -v "$tool")"
    else
      printf '  [skip] %s\n' "$tool"
    fi
  done

  printf '\ngit include:\n'
  if git config --global --get-all include.path 2>/dev/null | grep -Fqx "$(config_home)/gitconfig.include"; then
    printf '  [ok]   %s\n' "$(config_home)/gitconfig.include"
  else
    printf '  [miss] %s\n' "$(config_home)/gitconfig.include"
  fi

  printf '\npath:\n'
  if path_has_dir "${HOME}/.local/bin"; then
    printf '  [ok]   ~/.local/bin is in PATH\n'
  else
    printf '  [miss] ~/.local/bin is not in PATH\n'
    printf '  [hint] add this to %s:\n' "$(shell_rc_path)"
    printf '         export PATH="$HOME/.local/bin:$PATH"\n'
  fi

  printf '\nshell helpers:\n'
  if [ -n "${BGA_SHELL_LOADED:-}" ]; then
    printf '  [ok]   current shell already sourced bga.sh\n'
  elif [ -f "$(shell_helper_path)" ]; then
    printf '  [info] source %s to enable gwt/gcodex/gcline/gcockpit\n' "$(shell_helper_path)"
    if shell_rc_mentions_helper; then
      printf '  [ok]   shell rc references the helper file\n'
    else
      printf '  [hint] add this to %s:\n' "$(shell_rc_path)"
      printf '         source "%s"\n' "$(shell_helper_path)"
    fi
  else
    printf '  [miss] shell helper file not found\n'
  fi

  printf '\nlazygit config:\n'
  if [ -f "${HOME}/.config/lazygit/config.yml" ]; then
    printf '  [ok]   %s\n' "${HOME}/.config/lazygit/config.yml"
  else
    printf '  [info] run: bga lazygit-config install\n'
  fi

  printf '\ninteractive features:\n'
  if has fzf; then
    printf '  [ok]   fzf pickers are available\n'
  else
    printf '  [skip] fzf not found; menu/recent/worktree pickers fall back to simpler behavior\n'
  fi
  if has tmux; then
    printf '  [ok]   tmux cockpit is available\n'
  else
    printf '  [skip] tmux not found; cockpit layouts are unavailable\n'
  fi
  if has lazygit; then
    printf '  [ok]   lazygit integration is available\n'
  else
    printf '  [skip] lazygit not found; git status fallback will be used in tmux/git flows\n'
  fi

  printf '\nembedded assets:\n'
  if managed_lazygit_template_path >/dev/null 2>&1; then
    printf '  [ok]   %s\n' "$(managed_lazygit_template_path)"
  else
    printf '  [miss] lazygit template not found\n'
  fi

  printf '\nconfig:\n'
  if [ -f "$(user_config_file_path)" ]; then
    printf '  [ok]   user overrides: %s\n' "$(user_config_file_path)"
  else
    printf '  [info] no user overrides yet\n'
  fi
  if [ -f "$(repo_config_file_path || true)" ]; then
    printf '  [ok]   repo defaults: %s\n' "$(repo_config_file_path)"
  else
    printf '  [info] no repo defaults file (.bga.env) in this repo\n'
  fi
  while IFS= read -r key; do
    local_value="$(config_get "$key" || true)"
    [ -n "$local_value" ] || continue
    printf '         %s=%s\n' "$key" "$local_value"
  done <<'EOF'
base_branch
remote
cockpit_layout
workspace_root
protected_branches
EOF

  printf '\nnext steps:\n'
  if ! has fzf || ! has tmux || ! has lazygit || ! path_has_dir "${HOME}/.local/bin"; then
    printf '  - run: git bootstrap\n'
  fi
  if [ ! -f "${HOME}/.config/lazygit/config.yml" ]; then
    printf '  - run: git lazygit-config install\n'
  fi
  if [ -f "$(shell_helper_path)" ] && [ -z "${BGA_SHELL_LOADED:-}" ]; then
    printf '  - add shell helper to %s and reload your shell\n' "$(shell_rc_path)"
  fi

  [ "$missing" -eq 0 ] || return 1
}

cmd_release_check() {
  local version note_file status=0
  version="$(cat "${BGA_ROOT}/VERSION" 2>/dev/null || true)"
  [ -n "$version" ] || die "VERSION file is missing or empty"
  note_file="${BGA_ROOT}/release-notes/v${version}.md"

  printf 'release-check\n\n'

  if grep -Fq "Current version: \`${version}\`" "${BGA_ROOT}/README.md"; then
    printf '  [ok]   README current version matches %s\n' "$version"
  else
    printf '  [miss] README current version does not match %s\n' "$version"
    status=1
  fi

  if grep -Fq "## [${version}] -" "${BGA_ROOT}/CHANGELOG.md"; then
    printf '  [ok]   CHANGELOG has section for %s\n' "$version"
  else
    printf '  [miss] CHANGELOG is missing section for %s\n' "$version"
    status=1
  fi

  if [ -f "$note_file" ]; then
    printf '  [ok]   %s\n' "$note_file"
  else
    printf '  [miss] %s\n' "$note_file"
    status=1
  fi

  if git diff --quiet && git diff --cached --quiet; then
    printf '  [ok]   working tree is clean\n'
  else
    printf '  [miss] working tree has uncommitted changes\n'
    status=1
  fi

  if git rev-parse -q --verify "refs/tags/v${version}" >/dev/null 2>&1; then
    printf '  [info] tag v%s already exists\n' "$version"
  else
    printf '  [ok]   tag v%s does not exist yet\n' "$version"
  fi

  return "$status"
}

cmd_release_init() {
  local version="${1:-}" previous_tag note_file
  [ -n "$version" ] || die "usage: bga release-init <version>"
  note_file="${BGA_ROOT}/release-notes/v${version}.md"
  [ ! -f "$note_file" ] || die "release note already exists: $note_file"
  previous_tag="$(latest_version_tag)"

  {
    printf '# better-git-aliases v%s\n\n' "$version"
    printf 'Release summary.\n\n'
    printf '## Highlights\n\n'
    printf -- '- highlight 1\n'
    printf -- '- highlight 2\n'
    printf -- '- highlight 3\n\n'
    printf '## Commit summary\n\n'
    if [ -n "$previous_tag" ]; then
      git log --oneline "${previous_tag}..HEAD" | sed 's/^/- /'
    else
      git log --oneline | sed 's/^/- /'
    fi
    printf '\n## Notes\n\n'
    printf -- '- Version: `%s`\n' "$version"
    printf -- '- License: MIT\n'
  } >"$note_file"

  printf 'Created release note: %s\n' "$note_file"
  if [ -n "$previous_tag" ]; then
    printf 'Based on commits since: %s\n' "$previous_tag"
  else
    printf 'Based on all commits because no previous version tag was found.\n'
  fi
}

cmd_remote_info() {
  local parsed remote provider host path web_url raw_url
  parsed="$(remote_info_fields "${1:-$(config_get remote || printf 'origin')}")"
  remote="$(printf '%s' "$parsed" | cut -d'|' -f1)"
  provider="$(printf '%s' "$parsed" | cut -d'|' -f2)"
  host="$(printf '%s' "$parsed" | cut -d'|' -f3)"
  path="$(printf '%s' "$parsed" | cut -d'|' -f4)"
  web_url="$(printf '%s' "$parsed" | cut -d'|' -f5)"
  raw_url="$(printf '%s' "$parsed" | cut -d'|' -f6)"

  printf 'remote:    %s\n' "$remote"
  printf 'provider:  %s\n' "$provider"
  printf 'host:      %s\n' "$host"
  printf 'path:      %s\n' "$path"
  printf 'web url:   %s\n' "$web_url"
  printf 'git url:   %s\n' "$raw_url"
}

cmd_remote_status() {
  local base="${1:-$(default_base_branch)}" branch parsed provider web_url upstream counts parsed_counts ahead behind
  ensure_repo
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  parsed="$(remote_info_fields)"
  provider="$(printf '%s' "$parsed" | cut -d'|' -f2)"
  web_url="$(printf '%s' "$parsed" | cut -d'|' -f5)"
  upstream="$(branch_upstream "$branch")"

  printf 'branch:     %s\n' "$branch"
  printf 'base:       %s\n' "$base"
  printf 'provider:   %s\n' "$provider"
  printf 'repo url:   %s\n' "$web_url"
  printf 'compare:    '
  case "$provider" in
    github|gitlab)
      printf 'supported\n'
      printf 'compare url: %s\n' "$(compare_url "$base" "$branch")"
      ;;
    *)
      printf 'fallback only\n'
      ;;
  esac

  if [ -n "$upstream" ]; then
    counts="$(branch_ahead_behind "$branch" || true)"
    parsed_counts="$(parse_ahead_behind "$counts")"
    ahead="${parsed_counts%% *}"
    behind="${parsed_counts##* }"
    printf 'upstream:   %s\n' "$upstream"
    printf 'ahead/behind: %s / %s\n' "${ahead:-0}" "${behind:-0}"
  else
    printf 'upstream:   none\n'
    printf 'ahead/behind: n/a\n'
  fi
}

cmd_remote_open() {
  local parsed web_url
  parsed="$(remote_info_fields "${1:-$(config_get remote || printf 'origin')}")"
  web_url="$(printf '%s' "$parsed" | cut -d'|' -f5)"
  open_url "$web_url"
}

cmd_remote_compare() {
  local open_flag=0 base="" compare="" url parsed provider
  while [ $# -gt 0 ]; do
    case "$1" in
      --open)
        open_flag=1
        ;;
      *)
        if [ -z "$base" ]; then
          base="$1"
        elif [ -z "$compare" ]; then
          compare="$1"
        else
          die "usage: bga remote-compare [BASE] [COMPARE] [--open]"
        fi
        ;;
    esac
    shift || true
  done

  [ -n "$base" ] || base="$(default_base_branch)"
  [ -n "$compare" ] || compare="$(current_branch)"
  [ -n "$compare" ] || die "detached HEAD; provide COMPARE explicitly"

  parsed="$(remote_info_fields "${1:-$(config_get remote || printf 'origin')}")"
  provider="$(printf '%s' "$parsed" | cut -d'|' -f2)"
  url="$(compare_url "$base" "$compare")"

  case "$provider" in
    github|gitlab)
      if [ "$open_flag" -eq 1 ]; then
        open_url "$url"
      else
        printf '%s\n' "$url"
      fi
      ;;
    *)
      printf 'Compare URL is not provider-specific for %s yet.\n' "$provider"
      printf 'Open the repo URL and compare manually:\n'
      printf '%s\n' "$url"
      ;;
  esac
}

cmd_bootstrap() {
  local manager="${1:-auto}"
  if [ "$manager" = "auto" ]; then
    if has brew; then
      manager="brew"
    elif has apt-get; then
      manager="apt"
    else
      die "no supported package manager found; use brew or apt explicitly"
    fi
  fi

  case "$manager" in
    brew)
      has brew || die "brew is not installed"
      brew install git fzf lazygit tmux git-delta
      ;;
    apt)
      has apt-get || die "apt-get is not installed"
      sudo apt-get update
      sudo apt-get install -y git fzf tmux git-delta
      if ! has lazygit; then
        printf 'lazygit is not in standard apt repos on many systems; install it separately if needed.\n'
      fi
      ;;
    *)
      die "supported package managers: brew, apt"
      ;;
  esac
}

cmd_config() {
  local action="${1:-list}" key value
  shift || true
  case "$action" in
    get)
      key="${1:-}"
      [ -n "$key" ] || die "usage: bga config get <key>"
      config_get "$key"
      ;;
    set)
      key="${1:-}"
      value="${2:-}"
      [ -n "$key" ] || die "usage: bga config set <key> <value>"
      [ -n "$value" ] || die "usage: bga config set <key> <value>"
      config_set "$key" "$value"
      printf '%s=%s\n' "$key" "$value"
      ;;
    list)
      config_list
      ;;
    *)
      die "usage: bga config <get|set|list> ..."
      ;;
  esac
}

cmd_lazygit_config() {
  local action="${1:-install}"
  local target_dir="${HOME}/.config/lazygit"
  local target_file
  local source_file
  source_file="$(managed_lazygit_template_path)" || die "lazygit template not found; reinstall better-git-aliases"
  target_file="$(managed_lazygit_config_path)"
  case "$action" in
    install)
      mkdir -p "$target_dir"
      install -m 0644 "$source_file" "$target_file"
      printf 'Installed lazygit config: %s\n' "$target_file"
      ;;
    path)
      printf '%s\n' "$target_file"
      ;;
    diff)
      if [ ! -f "$target_file" ]; then
        die "lazygit config not found at $target_file"
      fi
      if command -v diff >/dev/null 2>&1; then
        diff -u "$target_file" "$source_file" || true
      else
        die "diff command is not available"
      fi
      ;;
    backup)
      if [ ! -f "$target_file" ]; then
        die "lazygit config not found at $target_file"
      fi
      local backup_dir backup_file
      backup_dir="$(backup_root)/lazygit"
      mkdir -p "$backup_dir"
      backup_file="${backup_dir}/config.$(timestamp).yml"
      cp "$target_file" "$backup_file"
      printf 'Backed up lazygit config to: %s\n' "$backup_file"
      ;;
    merge-hint)
      cat <<EOF
Managed template:
  $source_file

Current lazygit config:
  $target_file

Recommended merge flow:
  1. Back up your current config:
     bga lazygit-config backup
  2. Review differences:
     bga lazygit-config diff
  3. Keep your personal preferences and copy only the workflow-specific pieces:
     - customCommands
     - git.paging
     - keybinding overrides you actually want
  4. Re-install the managed version only if you want a full reset:
     bga lazygit-config install

Practical rule:
  Treat the bundled config as a reference baseline, not something you must overwrite every time.
EOF
      ;;
    *)
      die "usage: bga lazygit-config <install|path|diff|backup|merge-hint>"
      ;;
  esac
}

cmd_start_day() {
  ensure_repo
  printf '== doctor ==\n'
  cmd_doctor || true
  printf '\n== sync ==\n'
  cmd_sync 2>&1
  printf '\n== dashboard ==\n'
  cmd_dashboard
}

cmd_finish_day() {
  ensure_repo
  printf '== pause ==\n'
  cmd_feature_pause
  printf '\n== dashboard ==\n'
  cmd_dashboard
}

cmd_dashboard() {
  ensure_repo
  local root branch
  root="$(repo_root)"
  branch="$(current_branch)"
  printf 'repo:      %s\n' "$root"
  printf 'branch:    %s\n' "${branch:-detached}"
  printf 'base:      %s\n' "$(default_base_branch)"
  printf 'status:\n'
  git status -sb
  printf '\n'
  print_dashboard_attention
  printf '\n'
  print_dashboard_worktrees
  printf '\n'
  print_dashboard_recent_branches
}

cmd_sync() {
  ensure_repo
  local branch upstream
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  git fetch --all --prune
  upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" 2>/dev/null || true)"
  if [ -n "$upstream" ]; then
    git pull --rebase --autostash
  else
    printf 'No upstream set for %s. Fetched remotes only.\n' "$branch"
  fi
}

cmd_workspace_list() {
  local root="${1:-$(workspace_root)}" repo
  printf 'workspace root: %s\n\n' "$root"
  while IFS= read -r repo; do
    [ -n "$repo" ] || continue
    printf '%s\n' "$repo"
  done < <(workspace_repo_roots "$root")
}

cmd_workspace_dash() {
  local root="${1:-$(workspace_root)}" repo branch dirty upstream worktrees priority last_commit
  local total=0 dirty_count=0 no_upstream_count=0 ahead_behind_count=0
  printf 'workspace root: %s\n\n' "$root"
  while IFS='|' read -r repo branch dirty upstream worktrees priority last_commit; do
    [ -n "$repo" ] || continue
    total=$((total + 1))
    [ "$dirty" = "dirty" ] && dirty_count=$((dirty_count + 1))
    [ "$upstream" = "no upstream" ] && no_upstream_count=$((no_upstream_count + 1))
    case "$upstream" in
      ahead*)
        if [ "$upstream" != "ahead 0 / behind 0" ]; then
          ahead_behind_count=$((ahead_behind_count + 1))
        fi
        ;;
    esac
  done < <(sorted_workspace_repos "$root")

  printf 'attention:\n'
  printf '  repos:          %s\n' "$total"
  printf '  dirty:          %s\n' "$dirty_count"
  printf '  no upstream:    %s\n' "$no_upstream_count"
  printf '  ahead/behind:   %s\n\n' "$ahead_behind_count"

  while IFS='|' read -r repo branch dirty upstream worktrees priority last_commit; do
    [ -n "$repo" ] || continue
    printf '%s\n' "$repo"
    printf '  branch:    %s\n' "${branch:-detached}"
    printf '  status:    %s\n' "$dirty"
    printf '  upstream:  %s\n' "$upstream"
    printf '  worktrees: %s\n\n' "$worktrees"
  done < <(sorted_workspace_repos "$root")
}

cmd_workspace_recent() {
  local root="${1:-$(workspace_root)}"
  if can_use_fzf; then
    sorted_workspace_repos "$root" | fzf \
      --delimiter='|' \
      --with-nth=2,3,4,1 \
      --preview-window='right,65%,border-left' \
      --height=85% \
      --layout=reverse \
      --border \
      --prompt='recent-repo> ' \
      --header='branch | status | upstream | path' \
      --preview '
        path=$(printf "%s" {} | cut -d"|" -f1)
        if [ -d "$path" ]; then
          cd "$path" || exit 1
          printf "Path: %s\n\n" "$path"
          git status -sb
          printf "\nRecent commits:\n"
          git log --oneline --decorate -n 10
        fi
      ' \
      | cut -d'|' -f1
  else
    sorted_workspace_repos "$root" | column -t -s '|' | fzf_or_first "recent-repo> " | awk '{print $1}'
  fi
}

cmd_workspace_sync() {
  local root="${1:-$(workspace_root)}" repo branch upstream
  printf 'workspace root: %s\n\n' "$root"
  while IFS= read -r repo; do
    [ -n "$repo" ] || continue
    printf '==> %s\n' "$repo"
    (
      cd "$repo" || exit 1
      git fetch --all --prune
      branch="$(current_branch)"
      if [ -n "$branch" ]; then
        upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" 2>/dev/null || true)"
        if [ -n "$upstream" ]; then
          git pull --rebase --autostash
        else
          printf 'No upstream set for %s. Fetched remotes only.\n' "$branch"
        fi
      else
        printf 'Detached HEAD. Fetched remotes only.\n'
      fi
    )
    printf '\n'
  done < <(workspace_repo_roots "$root")
}

cmd_workspace_action() {
  local repo="${1:-}" action="${2:-dash}" layout
  [ -n "$repo" ] || die "usage: bga workspace action <repo-path> <dash|sync|lazygit|cockpit|codex|cline|path>"
  case "$action" in
    dash) (cd "$repo" && "${BGA_BIN_DIR}/bga" dashboard) ;;
    sync) (cd "$repo" && "${BGA_BIN_DIR}/bga" sync) ;;
    lazygit) open_lazygit "$repo" ;;
    cockpit)
      layout="$(config_get cockpit_layout || true)"
      open_tmux_workspace "$repo" "${layout:-solo}"
      ;;
    codex) open_ai_cli codex "$repo" ;;
    cline) open_ai_cli cline "$repo" ;;
    path) printf '%s\n' "$repo" ;;
    *) die "usage: bga workspace action <repo-path> <dash|sync|lazygit|cockpit|codex|cline|path>" ;;
  esac
}

cmd_workspace_menu() {
  local root="${1:-$(workspace_root)}" repo action
  repo="$(workspace_repo_picker "$root")"
  [ -n "$repo" ] || return 0
  printf 'workspace action:\n'
  printf '  1. dashboard\n'
  printf '  2. sync\n'
  printf '  3. lazygit\n'
  printf '  4. tmux cockpit\n'
  printf '  5. codex\n'
  printf '  6. cline\n'
  printf '  7. print path\n'
  action="$(prompt_input 'choose [1-7]: ')"
  case "$action" in
    1|"") cmd_workspace_action "$repo" dash ;;
    2) cmd_workspace_action "$repo" sync ;;
    3) cmd_workspace_action "$repo" lazygit ;;
    4) cmd_workspace_action "$repo" cockpit ;;
    5) cmd_workspace_action "$repo" codex ;;
    6) cmd_workspace_action "$repo" cline ;;
    7) cmd_workspace_action "$repo" path ;;
    *) die "invalid choice: $action" ;;
  esac
}

cmd_workspace() {
  local action="${1:-dash}"
  shift || true
  case "$action" in
    list) cmd_workspace_list "${1:-}" ;;
    dash) cmd_workspace_dash "${1:-}" ;;
    recent) cmd_workspace_recent "${1:-}" ;;
    sync) cmd_workspace_sync "${1:-}" ;;
    menu) cmd_workspace_menu "${1:-}" ;;
    action) cmd_workspace_action "${1:-}" "${2:-}" ;;
    *) die "usage: bga workspace <list|dash|recent|sync|menu> [ROOT]" ;;
  esac
}

cmd_review() {
  ensure_repo
  case "${1:-default}" in
    default)
      if has lazygit; then
        open_lazygit "."
      else
        cmd_review status
      fi
      ;;
    status)
      printf 'Review status\n\n'
      git status -sb
      printf '\nRecent commits:\n'
      git log --oneline -n 8
      ;;
    diff)
      if has lazygit; then
        open_lazygit "."
      else
        git diff --stat
        printf '\n'
        git diff
      fi
      ;;
    *)
      die "usage: bga review [status|diff]"
      ;;
  esac
}

cmd_recent() {
  ensure_repo
  local selected
  selected="$(branch_picker)"
  [ -n "${selected:-}" ] || exit 0
  git checkout "${selected#origin/}"
}

cmd_commits() {
  ensure_repo
  if has fzf; then
    git log --graph --color=always \
      --pretty=format:'%C(auto)%h%d %s %C(black)%C(bold)%cr %C(auto)<%an>' \
      --abbrev-commit \
      | fzf --ansi --no-sort --reverse --tiebreak=index \
          --height=85% \
          --border \
          --preview-window='right,65%,border-left' \
          --preview 'echo {} | grep -o "[a-f0-9]\{7,\}" | head -n1 | xargs -r git show --color=always --stat --patch' \
          --prompt='commit> '
  else
    git log --oneline --decorate -n 30
  fi
}

cmd_prune_merged() {
  ensure_repo
  local protected current
  current="$(current_branch)"
  protected="$(protected_branches_regex "$current")"
  while read -r branch; do
    [ -n "$branch" ] || continue
    git branch -d "$branch"
  done < <(
    git branch --merged \
      | sed 's/^[* ]*//' \
      | grep -Ev "^(${protected})$" || true
  )
}

cmd_feature_start() {
  ensure_repo
  local name base branch target_root target_path
  name="${1:-}"
  base="${2:-$(default_base_branch)}"
  [ -n "$name" ] || die "usage: bga feature start <name> [base]"
  branch="feature/${name}"
  target_root="$(worktree_root)"
  target_path="${target_root}/${branch//\//-}"

  mkdir -p "$target_root"
  git fetch --all --prune

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    git worktree add "$target_path" "$branch" >/dev/null
  else
    git worktree add -b "$branch" "$target_path" "$base" >/dev/null
  fi

  printf '%s\n' "$target_path"
}

cmd_feature_resume() {
  ensure_repo
  local query="" action="print" target
  while [ $# -gt 0 ]; do
    case "$1" in
      --print) action="print" ;;
      --lazygit) action="lazygit" ;;
      --cockpit) action="cockpit" ;;
      *) query="$1" ;;
    esac
    shift || true
  done
  target="$(resolve_worktree_path "$query")"
  [ -n "$target" ] || return 0
  case "$action" in
    print) printf '%s\n' "$target" ;;
    lazygit) open_lazygit "$target" ;;
    cockpit) open_tmux_workspace "$target" "solo" ;;
    *) die "unknown feature resume action: $action" ;;
  esac
}

cmd_feature_pause() {
  ensure_repo
  local branch root counts parsed ahead behind resume_query
  root="$(repo_root)"
  branch="$(current_branch)"
  resume_query="${branch#feature/}"
  [ -n "$resume_query" ] || resume_query="$branch"
  printf 'Feature pause summary\n\n'
  printf 'repo:    %s\n' "$root"
  printf 'branch:  %s\n' "${branch:-detached}"
  printf 'base:    %s\n' "$(default_base_branch)"
  case "${branch:-}" in
    feature/*) ;;
    *)
      printf 'note:    current branch does not use feature/* naming\n'
      ;;
  esac
  printf '\nstatus:\n'
  git status -sb
  printf '\nrecent commits:\n'
  git log --oneline -n 5
  printf '\nupstream:\n'
  counts="$(branch_ahead_behind "${branch:-HEAD}" || true)"
  if [ -n "$counts" ]; then
    parsed="$(parse_ahead_behind "$counts")"
    ahead="${parsed%% *}"
    behind="${parsed##* }"
    printf '  ahead %s / behind %s\n' "${ahead:-0}" "${behind:-0}"
  else
    printf '  no upstream\n'
  fi
  printf '\nresume commands:\n'
  printf '  git feature resume %s --lazygit\n' "$resume_query"
  printf '  git feature resume %s --cockpit\n' "$resume_query"
  printf '\nnext-step note:\n'
  printf '  branch=%s\n' "${branch:-detached}"
  printf '  todo=describe the next concrete change before you stop\n'
  printf '  blocker=record any open blocker or dependency\n'
}

cmd_feature_ship() {
  ensure_repo
  local branch
  branch="$(current_branch)"
  printf 'Branch: %s\n' "${branch:-detached}"
  printf '\nStatus:\n'
  git status -sb
  printf '\nAhead/behind:\n'
  git rev-list --left-right --count HEAD..."@{upstream}" 2>/dev/null || printf 'no upstream\n'
  printf '\nRecent commits:\n'
  git log --oneline -n 5
}

cmd_feature_submit() {
  ensure_repo
  local base="" branch
  while [ $# -gt 0 ]; do
    case "$1" in
      *) base="$1" ;;
    esac
    shift || true
  done
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  [ -n "$base" ] || base="$(default_base_branch)"

  cmd_feature_ship
  printf '\nSubmit flow:\n'
  cmd_github_publish
  printf '\nNext:\n'
  printf '  - open your Git hosting web UI\n'
  printf '  - create a PR/MR from %s to %s\n' "$branch" "$base"
}

cmd_feature_finish() {
  ensure_repo
  local branch="" base="" current_path path current_branch_name deleted_branch=0
  current_branch_name="$(current_branch)"
  current_path="$(current_worktree_path)"

  while [ $# -gt 0 ]; do
    case "$1" in
      --base)
        shift
        [ -n "${1:-}" ] || die "usage: bga feature finish [BRANCH] [--base BASE]"
        base="$1"
        ;;
      *)
        branch="$1"
        ;;
    esac
    shift || true
  done

  [ -n "$branch" ] || branch="$current_branch_name"
  [ -n "$branch" ] || die "usage: bga feature finish [BRANCH] [--base BASE]"
  [ -n "$base" ] || base="$(default_base_branch)"

  branch_is_merged_into "$branch" "$base" || die "branch '$branch' is not merged into '$base'"

  printf 'Finishing branch: %s\n' "$branch"
  printf 'Base branch:      %s\n' "$base"

  while IFS='|' read -r path _; do
    [ -n "$path" ] || continue
    if [ "$path" = "$current_path" ]; then
      printf 'Skip current worktree: %s\n' "$path"
      continue
    fi
    if ! managed_worktree_path "$path"; then
      printf 'Skip unmanaged worktree: %s\n' "$path"
      continue
    fi
    git worktree remove "$path"
    printf 'Removed worktree: %s\n' "$path"
  done < <(branch_worktrees "$branch")

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    if git branch -d "$branch" >/dev/null 2>&1; then
      printf 'Deleted local branch: %s\n' "$branch"
      deleted_branch=1
    else
      printf 'Skipped deleting branch (still checked out in a worktree): %s\n' "$branch"
    fi
  fi

  [ "$deleted_branch" -eq 1 ] || true
}

cmd_feature_cleanup() {
  ensure_repo
  local branch="" base="" apply=0 protected
  while [ $# -gt 0 ]; do
    case "$1" in
      --base)
        shift
        [ -n "${1:-}" ] || die "usage: bga feature cleanup [BRANCH] [--base BASE] [--apply]"
        base="$1"
        ;;
      --apply)
        apply=1
        ;;
      *)
        branch="$1"
        ;;
    esac
    shift || true
  done
  [ -n "$branch" ] || branch="$(current_branch)"
  [ -n "$branch" ] || die "usage: bga feature cleanup [BRANCH] [--base BASE] [--apply]"
  [ -n "$base" ] || base="$(default_base_branch)"

  printf 'Feature cleanup:\n'
  printf '  branch: %s\n' "$branch"
  printf '  base:   %s\n' "$base"

  if branch_is_merged_into "$branch" "$base"; then
    printf '  merged: yes\n'
  else
    printf '  merged: no\n'
    die "branch '$branch' is not merged into '$base'"
  fi

  printf '\nWorktrees for branch:\n'
  if branch_worktrees "$branch" | grep . >/dev/null 2>&1; then
    branch_worktrees "$branch" | column -t -s '|'
  else
    printf '  none\n'
  fi

  printf '\nStale managed worktrees:\n'
  cmd_worktree_stale "$base"

  printf '\nMerged branch cleanup preview:\n'
  protected="$(protected_branches_regex "$branch")"
  git branch --merged \
    | sed 's/^[* ]*//' \
    | grep -Ev "^(${protected})$" \
    | awk 'NF { print "  " $0 }' || true

  if [ "$apply" -eq 0 ]; then
    printf '\nDry run. Re-run with --apply to perform cleanup.\n'
    return 0
  fi

  printf '\nApplying cleanup:\n'
  cmd_feature_finish "$branch" --base "$base"
  printf '\nCleaning stale managed worktrees:\n'
  cmd_worktree_clean "$base" --apply
  printf '\nPruning merged local branches:\n'
  cmd_prune_merged
}

cmd_worktree_list() {
  ensure_repo
  list_worktrees | column -t -s '|'
}

cmd_worktree_stale() {
  ensure_repo
  local base="${1:-$(default_base_branch)}"
  local current_path branch path found=0
  current_path="$(current_worktree_path)"

  while IFS='|' read -r path branch; do
    [ -n "$path" ] || continue
    [ -n "$branch" ] || continue
    [ "$branch" = "detached" ] && continue
    [ "$branch" = "$base" ] && continue
    [ "$path" = "$current_path" ] && continue
    managed_worktree_path "$path" || continue
    if branch_is_merged_into "$branch" "$base"; then
      printf '%s|%s|merged-into-%s\n' "$path" "$branch" "$base"
      found=1
    fi
  done < <(list_worktrees)

  [ "$found" -eq 1 ] || printf 'No stale managed worktrees found.\n'
}

cmd_worktree_clean() {
  ensure_repo
  local apply=0 base="" path branch reason
  while [ $# -gt 0 ]; do
    case "$1" in
      --apply)
        apply=1
        ;;
      *)
        base="$1"
        ;;
    esac
    shift || true
  done
  [ -n "$base" ] || base="$(default_base_branch)"

  if [ "$apply" -eq 0 ]; then
    printf 'Dry run. Use --apply to remove these stale managed worktrees.\n\n'
  fi

  while IFS='|' read -r path branch reason; do
    case "$path" in
      No\ stale\ managed\ worktrees\ found.) printf '%s\n' "$path"; return 0 ;;
    esac
    [ -n "$path" ] || continue
    if [ "$apply" -eq 1 ]; then
      git worktree remove "$path"
      printf 'Removed: %s (%s)\n' "$path" "$branch"
    else
      printf 'Would remove: %s (%s, %s)\n' "$path" "$branch" "$reason"
    fi
  done < <(cmd_worktree_stale "$base")
}

resolve_worktree_path() {
  ensure_repo
  local query="${1:-}"
  if [ -n "$query" ] && [ -d "$query" ]; then
    printf '%s\n' "$query"
    return 0
  fi

  if [ -n "$query" ]; then
    local match
    match="$(list_worktrees | grep -E "${query}" | head -n 1 | cut -d'|' -f1 || true)"
    [ -n "$match" ] && printf '%s\n' "$match" && return 0
  fi

  worktree_picker
}

cmd_worktree_add() {
  ensure_repo
  local name="${1:-}" base="${2:-$(default_base_branch)}" branch target_root target_path
  [ -n "$name" ] || die "usage: bga worktree add <branch-or-name> [base]"
  branch="$name"
  target_root="$(worktree_root)"
  target_path="${target_root}/${branch//\//-}"
  mkdir -p "$target_root"
  git fetch --all --prune

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    git worktree add "$target_path" "$branch" >/dev/null
  else
    git worktree add -b "$branch" "$target_path" "$base" >/dev/null
  fi

  printf '%s\n' "$target_path"
}

cmd_worktree_path() {
  local selected
  selected="$(resolve_worktree_path "${1:-}")"
  [ -n "${selected:-}" ] || exit 0
  printf '%s\n' "$selected"
}

cmd_worktree_remove() {
  ensure_repo
  local target
  target="$(resolve_worktree_path "${1:-}")"
  [ -n "${target:-}" ] || exit 0
  git worktree remove "$target"
}

cmd_worktree_tmux() {
  local target_query="" target layout="solo"
  while [ $# -gt 0 ]; do
    case "$1" in
      --layout)
        shift
        [ -n "${1:-}" ] || die "usage: bga worktree tmux [QUERY] [--layout LAYOUT]"
        layout="$1"
        ;;
      *)
        target_query="$1"
        ;;
    esac
    shift || true
  done
  target="$(resolve_worktree_path "$target_query")"
  [ -n "${target:-}" ] || exit 0
  open_tmux_workspace "$target" "$layout"
}

cmd_worktree_lazygit() {
  local target
  target="$(resolve_worktree_path "${1:-}")"
  [ -n "${target:-}" ] || exit 0
  open_lazygit "$target"
}

cmd_lazygit() {
  if [ $# -gt 0 ]; then
    cmd_worktree_lazygit "$1"
  else
    open_lazygit "."
  fi
}

cmd_codex() {
  local target="."
  [ $# -gt 0 ] && target="$(resolve_worktree_path "$1")"
  open_ai_cli codex "$target"
}

cmd_cline() {
  local target="."
  [ $# -gt 0 ] && target="$(resolve_worktree_path "$1")"
  open_ai_cli cline "$target"
}

cmd_github_repo() {
  ensure_repo
  local open_flag=0 url
  if [ "${1:-}" = "--open" ]; then
    open_flag=1
  fi
  url="$(github_https_remote_url origin)"
  if [ "$open_flag" -eq 1 ]; then
    open_url "$url"
  else
    printf '%s\n' "$url"
  fi
}

cmd_github_status() {
  ensure_repo
  local base="" branch repo_url compare_url pr_url upstream counts parsed ahead behind
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  [ -n "${1:-}" ] && base="$1" || base="$(default_base_branch)"
  repo_url="$(github_https_remote_url origin)"
  compare_url="${repo_url}/compare/${base}...${branch}?expand=1"
  pr_url="${repo_url}/compare/${base}...${branch}?expand=1&template=pull_request_template.md"
  upstream="$(branch_upstream "$branch")"

  printf 'repo:     %s\n' "$repo_url"
  printf 'branch:   %s\n' "$branch"
  printf 'base:     %s\n' "$base"
  if [ -n "$upstream" ]; then
    counts="$(branch_ahead_behind "$branch" || true)"
    parsed="$(parse_ahead_behind "$counts")"
    ahead="${parsed%% *}"
    behind="${parsed##* }"
    printf 'upstream: %s\n' "$upstream"
    printf 'publish:  yes (ahead %s / behind %s)\n' "${ahead:-0}" "${behind:-0}"
  else
    printf 'upstream: none\n'
    printf 'publish:  no\n'
  fi
  printf 'compare:  %s\n' "$compare_url"
  printf 'pr:       %s\n' "$pr_url"
}

cmd_github_publish() {
  ensure_repo
  local branch upstream
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  upstream="$(branch_upstream "$branch")"
  if [ -n "$upstream" ]; then
    git push
  else
    git push -u origin "$branch"
  fi
}

cmd_github_submit() {
  ensure_repo
  local base="" open_flag=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --open) open_flag=1 ;;
      *) base="$1" ;;
    esac
    shift || true
  done
  cmd_github_publish
  if [ "$open_flag" -eq 1 ]; then
    if [ -n "$base" ]; then
      cmd_github_pr "$base" --open
    else
      cmd_github_pr --open
    fi
  else
    if [ -n "$base" ]; then
      cmd_github_pr "$base"
    else
      cmd_github_pr
    fi
  fi
}

cmd_github_compare() {
  ensure_repo
  local base="" open_flag=0 branch url repo_url
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  while [ $# -gt 0 ]; do
    case "$1" in
      --open) open_flag=1 ;;
      *) base="$1" ;;
    esac
    shift || true
  done
  [ -n "$base" ] || base="$(default_base_branch)"
  repo_url="$(github_https_remote_url origin)"
  url="${repo_url}/compare/${base}...${branch}?expand=1"
  if [ "$open_flag" -eq 1 ]; then
    open_url "$url"
  else
    printf '%s\n' "$url"
  fi
}

cmd_github_pr() {
  ensure_repo
  local base="" open_flag=0 branch url repo_url
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  while [ $# -gt 0 ]; do
    case "$1" in
      --open) open_flag=1 ;;
      *) base="$1" ;;
    esac
    shift || true
  done
  [ -n "$base" ] || base="$(default_base_branch)"
  repo_url="$(github_https_remote_url origin)"
  url="${repo_url}/compare/${base}...${branch}?expand=1&template=pull_request_template.md"
  if [ "$open_flag" -eq 1 ]; then
    open_url "$url"
  else
    printf '%s\n' "$url"
  fi
}

cmd_cockpit() {
  local target="." layout=""
  layout="$(config_get cockpit_layout || true)"
  [ -n "$layout" ] || layout="solo"
  if [ "${1:-}" = "list-layouts" ]; then
    printf 'solo\nreview\nai-pair\nmulti-feature\n'
    return 0
  fi
  while [ $# -gt 0 ]; do
    case "$1" in
      --layout)
        shift
        [ -n "${1:-}" ] || die "usage: bga cockpit [QUERY] [--layout LAYOUT]"
        layout="$1"
        ;;
      *)
        target="$(resolve_worktree_path "$1")"
        ;;
    esac
    shift || true
  done
  open_tmux_workspace "$target" "$layout"
}

cmd_init() {
  local shell_name="${1:-bash}"
  local helper
  helper="$(shell_helper_path)"
  case "$shell_name" in
    bash|zsh)
      cat <<EOF
source "${helper}"
EOF
      ;;
    *)
      die "supported shells: bash, zsh"
      ;;
  esac
}

prompt_input() {
  local label="$1" value
  printf '%s' "$label"
  read -r value
  printf '%s\n' "$value"
}

menu_prompt_feature_start() {
  local name base
  name="$(prompt_input 'feature name: ')"
  [ -n "$name" ] || return 0
  base="$(prompt_input "base branch [$(default_base_branch)]: ")"
  if [ -n "$base" ]; then
    cmd_feature_start "$name" "$base"
  else
    cmd_feature_start "$name"
  fi
}

menu_prompt_resume_feature() {
  local target action layout
  target="$(resolve_worktree_path "${1:-}")"
  [ -n "$target" ] || return 0
  printf 'resume action:\n'
  printf '  1. jump path only\n'
  printf '  2. open lazygit\n'
  printf '  3. open tmux cockpit\n'
  action="$(prompt_input 'choose [1/2/3]: ')"
  case "$action" in
    1|"")
      printf '%s\n' "$target"
      ;;
    2)
      open_lazygit "$target"
      ;;
    3)
      layout="$(prompt_input 'layout [solo]: ')"
      open_tmux_workspace "$target" "${layout:-solo}"
      ;;
    *)
      die "invalid choice: $action"
      ;;
  esac
}

menu_review_and_commit() {
  if has lazygit; then
    open_lazygit "."
  else
    printf 'lazygit is not installed. Showing git status instead.\n\n'
    git status -sb
    printf '\nTip: install lazygit for the best review workflow.\n'
  fi
}

menu_cleanup_merged_work() {
  local apply
  printf 'cleanup preview:\n\n'
  cmd_worktree_clean
  printf '\n'
  cmd_prune_merged
  printf '\n'
  apply="$(prompt_input 'apply stale worktree cleanup now? [y/N]: ')"
  case "$apply" in
    y|Y|yes|YES)
      cmd_worktree_clean --apply
      ;;
  esac
}

run_menu_action() {
  local label="$1"
  case "$label" in
    "Start the workday") cmd_start_day ;;
    "Finish the workday") cmd_finish_day ;;
    "Start a new feature") menu_prompt_feature_start ;;
    "Resume existing feature") menu_prompt_resume_feature ;;
    "Pause current feature") cmd_feature_pause ;;
    "Review and commit changes") cmd_review ;;
    "Submit current feature for review") cmd_feature_submit ;;
    "Clean up current feature after merge") cmd_feature_cleanup ;;
    "Clean up merged work") menu_cleanup_merged_work ;;
    "Workspace overview") cmd_workspace dash ;;
    "Workspace action menu") cmd_workspace menu ;;
    "Sync all repos in workspace") cmd_workspace sync ;;
    "Doctor") cmd_doctor ;;
    "Configure defaults") cmd_config list ;;
    "Bootstrap dependencies") cmd_bootstrap ;;
    "Install lazygit config") cmd_lazygit_config install ;;
    "Dashboard") cmd_dashboard ;;
    "Sync current branch") cmd_sync ;;
    "Checkout recent branch") cmd_recent ;;
    "Browse commits") cmd_commits ;;
    "Create feature worktree") menu_prompt_feature_start ;;
    "List worktrees") cmd_worktree_list ;;
    "Open worktree in lazygit") cmd_worktree_lazygit ;;
    "Open worktree cockpit (tmux)") cmd_worktree_tmux ;;
    "Prune merged branches") cmd_prune_merged ;;
    "Show remote status") cmd_remote_status ;;
    "Open remote repo") cmd_remote_open ;;
    "Open remote compare") cmd_remote_compare --open ;;
    "Help") cmd_help ;;
  esac
}

menu_preview() {
  case "$1" in
    "Doctor")
      cat <<'EOF'
Check whether the local environment is ready.

Shows:
- required tools
- recommended tools
- git include installation
- shell helper status
EOF
      ;;
    "Configure defaults")
      cat <<'EOF'
Inspect or change defaults such as:
- base_branch
- remote
- cockpit_layout
- workspace_root
- protected_branches

Resolution order:
- user overrides from config-bga
- repo defaults from .bga.env
- built-in defaults
EOF
      ;;
    "Start the workday")
      cat <<'EOF'
Run the recommended start-of-day sequence.

Includes:
- doctor
- sync
- dashboard
EOF
      ;;
    "Finish the workday")
      cat <<'EOF'
Run the recommended end-of-day sequence.

Includes:
- feature pause
- dashboard
EOF
      ;;
    "Start a new feature")
      cat <<'EOF'
Guided feature setup.

Prompts for:
- feature name
- optional base branch

Then creates a dedicated feature branch and matching worktree.
EOF
      ;;
    "Submit current feature for review")
      cat <<'EOF'
Show the feature ship summary, then publish the branch.

Good when:
- local work is ready for review
- you want one command from final check to published branch
- your team opens PRs/MRs directly in the web UI
EOF
      ;;
    "Clean up current feature after merge")
      cat <<'EOF'
Preview cleanup for the current feature branch after merge.

Behavior:
- checks whether the branch is merged into the base branch
- shows related worktrees
- previews stale worktree and merged branch cleanup
- requires --apply in CLI usage for destructive cleanup
EOF
      ;;
    "Show GitHub status for current branch")
      cat <<'EOF'
Optional helper for GitHub-based workflows.

Shows:
- repo URL
- branch and base
- upstream/publish state
- compare URL
- PR URL
EOF
      ;;
    "Publish current branch to GitHub")
      cat <<'EOF'
Optional helper for GitHub-based workflows.

Push the current branch to origin.
EOF
      ;;
    "Publish branch and open PR flow")
      cat <<'EOF'
Optional helper for GitHub-based workflows.

Push the current branch first, then open the GitHub PR page.
EOF
      ;;
    "Open GitHub compare for current branch")
      cat <<'EOF'
Optional helper for GitHub-based workflows.

Open the GitHub compare page for the current branch.
EOF
      ;;
    "Open GitHub PR page for current branch")
      cat <<'EOF'
Optional helper for GitHub-based workflows.

Open the GitHub new-PR page for the current branch.
EOF
      ;;
    "Resume existing feature")
      cat <<'EOF'
Resume a feature worktree.

Options:
- print the path
- open lazygit
- open tmux cockpit
EOF
      ;;
    "Pause current feature")
      cat <<'EOF'
Show a structured handoff summary for the current feature.

Useful before:
- stopping for the day
- switching to another task
- handing work to someone else
EOF
      ;;
    "Review and commit changes")
      cat <<'EOF'
Open the recommended review flow before commit or submit.

Behavior:
- opens lazygit when available
- otherwise shows status and recent commits
EOF
      ;;
    "Clean up merged work")
      cat <<'EOF'
Preview stale managed worktrees and merged branches.

Behavior:
- shows a dry-run cleanup
- lets you confirm managed worktree cleanup
- also prunes merged local branches
EOF
      ;;
    "Workspace overview")
      cat <<'EOF'
Show all detected repos under the workspace root.

Useful when:
- you are juggling several repos in the same parent directory
- you want a quick branch/dirty/worktree summary across repos

Tip:
- set a fixed root with: git config-bga set workspace_root /path/to/workspace
EOF
      ;;
    "Workspace action menu")
      cat <<'EOF'
Pick one repo from the workspace, then choose a focused action.

Actions:
- dashboard
- sync
- lazygit
- tmux cockpit
- codex
- cline
- print path
EOF
      ;;
    "Sync all repos in workspace")
      cat <<'EOF'
Fetch all repos under the workspace root and rebase branches that already have an upstream.

Useful when:
- you start the day across several active repos
- you want a safe batch sync without leaving the terminal

Tip:
- set a fixed root with: git config-bga set workspace_root /path/to/workspace
EOF
      ;;
    "Bootstrap dependencies")
      cat <<'EOF'
Install recommended dependencies.

Supported:
- brew
- apt

Use this on a fresh machine before relying on menu, fzf, tmux, or lazygit workflows.
EOF
      ;;
    "Install lazygit config")
      cat <<'EOF'
Install the curated lazygit config for this workflow.

Includes:
- cleaner UI defaults
- git pager via delta
- shortcuts for bga/tmux/codex/cline flows
EOF
      ;;
    "Dashboard")
      cat <<'EOF'
Repo summary for quick orientation.

Shows:
- current repo root
- current branch
- git status
- worktrees
- recent branches
EOF
      ;;
    "Sync current branch")
      cat <<'EOF'
Fetch remotes and rebase current branch if it has an upstream.

Good start-of-day command.
EOF
      ;;
    "Checkout recent branch")
      cat <<'EOF'
Open a fuzzy branch picker.

Preview:
- recent commits
- stats
- decorations
EOF
      ;;
    "Browse commits")
      cat <<'EOF'
Open commit history with patch preview.

Useful for:
- reviewing recent work
- copying commit hashes
- understanding branch history
EOF
      ;;
    "Create feature worktree")
      cat <<'EOF'
Create a new feature branch and matching worktree.

Pattern:
- branch: feature/<name>
- path: ../.worktrees/<repo>/feature-<name>
EOF
      ;;
    "List worktrees")
      cat <<'EOF'
Show all worktrees attached to the current repo.

Use this when juggling multiple features.
EOF
      ;;
    "Open worktree in lazygit")
      cat <<'EOF'
Select a worktree and launch lazygit inside it.

Best for:
- staging hunks
- reviewing diffs
- branch and stash inspection
EOF
      ;;
    "Open worktree cockpit (tmux)")
      cat <<'EOF'
Select a worktree and open a tmux session around it.

Typical windows:
- shell
- git/lazygit
- codex or cline

Layouts:
- solo
- review
- ai-pair
- multi-feature
EOF
      ;;
    "Prune merged branches")
      cat <<'EOF'
Delete merged local branches, excluding protected names.

Protected by default:
- main
- master
- develop
- dev
- current branch

Override with:
- protected_branches in .bga.env
- protected_branches via git config-bga set
EOF
      ;;
    "Show remote status")
      cat <<'EOF'
Show the current branch, base branch, provider, upstream state, and compare readiness.

Useful when:
- you are not sure what the current remote can support safely
- you switch between GitHub, GitLab, Azure DevOps, and generic hosts
EOF
      ;;
    "Open remote repo")
      cat <<'EOF'
Open the current remote's parsed web URL.

Useful when:
- you want to jump to the hosting UI without caring about provider-specific URL formats
EOF
      ;;
    "Open remote compare")
      cat <<'EOF'
Open a compare URL for supported providers.

Behavior:
- GitHub and GitLab open compare URLs
- unsupported providers fall back safely to the repo URL with guidance
EOF
      ;;
    "Help")
      cat <<'EOF'
Show the full command reference.
EOF
      ;;
  esac
}

cmd_menu() {
  local items selected
  items=$'Start the workday\nFinish the workday\nStart a new feature\nResume existing feature\nPause current feature\nReview and commit changes\nSubmit current feature for review\nClean up current feature after merge\nClean up merged work\nWorkspace overview\nWorkspace action menu\nSync all repos in workspace\nDoctor\nConfigure defaults\nBootstrap dependencies\nInstall lazygit config\nDashboard\nSync current branch\nCheckout recent branch\nBrowse commits\nCreate feature worktree\nList worktrees\nOpen worktree in lazygit\nOpen worktree cockpit (tmux)\nPrune merged branches\nShow remote status\nOpen remote repo\nOpen remote compare\nShow GitHub status for current branch\nPublish current branch to GitHub\nPublish branch and open PR flow\nOpen GitHub compare for current branch\nOpen GitHub PR page for current branch\nHelp'
  if has fzf; then
    selected="$(printf '%s\n' "$items" | fzf \
      --height=80% \
      --layout=reverse \
      --border \
      --preview-window='right,55%,border-left,wrap' \
      --prompt='menu> ' \
      --header='better-git-aliases menu' \
      --preview "\"${BGA_BIN_DIR}/bga\" __menu-preview {}" )"
  else
    printf '%s\n' "$items"
    printf 'select exactly one label: '
    read -r selected
  fi
  [ -n "${selected:-}" ] || exit 0
  run_menu_action "$selected"
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    __menu-preview) menu_preview "${1:-}" ;;
    help|-h|--help) cmd_help ;;
    doctor) cmd_doctor ;;
    release-check) cmd_release_check ;;
    release-init) cmd_release_init "$@" ;;
    remote-info) cmd_remote_info "$@" ;;
    remote-status) cmd_remote_status "$@" ;;
    remote-open) cmd_remote_open "$@" ;;
    remote-compare) cmd_remote_compare "$@" ;;
    config) cmd_config "$@" ;;
    bootstrap) cmd_bootstrap "$@" ;;
    lazygit-config) cmd_lazygit_config "$@" ;;
    start-day) cmd_start_day "$@" ;;
    finish-day) cmd_finish_day "$@" ;;
    menu) cmd_menu ;;
    dashboard|dash) cmd_dashboard ;;
    workspace) cmd_workspace "$@" ;;
    sync) cmd_sync ;;
    review) cmd_review "$@" ;;
    recent) cmd_recent ;;
    commits) cmd_commits ;;
    prune-merged) cmd_prune_merged ;;
    feature)
      case "${1:-}" in
        start) shift; cmd_feature_start "$@" ;;
        resume) shift; cmd_feature_resume "$@" ;;
        pause) shift; cmd_feature_pause "$@" ;;
        ship) shift; cmd_feature_ship "$@" ;;
        submit) shift; cmd_feature_submit "$@" ;;
        cleanup) shift; cmd_feature_cleanup "$@" ;;
        finish) shift; cmd_feature_finish "$@" ;;
        *) die "usage: bga feature <start|resume|pause|ship|submit|cleanup|finish> ..." ;;
      esac
      ;;
    worktree|wt)
      case "${1:-list}" in
        list) shift; cmd_worktree_list "$@" ;;
        stale) shift; cmd_worktree_stale "$@" ;;
        clean) shift; cmd_worktree_clean "$@" ;;
        add) shift; cmd_worktree_add "$@" ;;
        path) shift; cmd_worktree_path "$@" ;;
        remove|rm) shift; cmd_worktree_remove "$@" ;;
        tmux) shift; cmd_worktree_tmux "$@" ;;
        lazygit|lg) shift; cmd_worktree_lazygit "$@" ;;
        *) die "usage: bga worktree <list|stale|clean|add|path|remove|tmux|lazygit> ..." ;;
      esac
      ;;
    lazygit|lg) cmd_lazygit "$@" ;;
    codex) cmd_codex "$@" ;;
    cline) cmd_cline "$@" ;;
    github)
      case "${1:-}" in
        repo) shift; cmd_github_repo "$@" ;;
        status) shift; cmd_github_status "$@" ;;
        publish) shift; cmd_github_publish "$@" ;;
        submit) shift; cmd_github_submit "$@" ;;
        compare) shift; cmd_github_compare "$@" ;;
        pr) shift; cmd_github_pr "$@" ;;
        *) die "usage: bga github <repo|status|publish|submit|compare|pr> [--open]" ;;
      esac
      ;;
    cockpit) cmd_cockpit "$@" ;;
    init) cmd_init "$@" ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
