#!/usr/bin/env bash
set -euo pipefail

BGA_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BGA_ROOT="$(cd "${BGA_BIN_DIR}/.." && pwd)"

has() {
  command -v "$1" >/dev/null 2>&1
}

config_home() {
  printf '%s/.config/better-git-aliases\n' "${HOME}"
}

asset_path() {
  local rel="$1"
  if [ -f "${BGA_ROOT}/${rel}" ]; then
    printf '%s\n' "${BGA_ROOT}/${rel}"
    return 0
  fi
  if [ -f "$(config_home)/${rel}" ]; then
    printf '%s\n' "$(config_home)/${rel}"
    return 0
  fi
  return 1
}

shell_helper_path() {
  if [ -f "${BGA_ROOT}/shell/bga.sh" ]; then
    printf '%s\n' "${BGA_ROOT}/shell/bga.sh"
    return 0
  fi
  if [ -f "$(config_home)/shell/bga.sh" ]; then
    printf '%s\n' "$(config_home)/shell/bga.sh"
    return 0
  fi
  printf '%s\n' "${BGA_ROOT}/shell/bga.sh"
}

managed_lazygit_template_path() {
  if [ -f "${BGA_ROOT}/config/lazygit/config.yml" ]; then
    printf '%s\n' "${BGA_ROOT}/config/lazygit/config.yml"
    return 0
  fi
  asset_path "lazygit/template.yml"
}

managed_lazygit_config_path() {
  printf '%s/.config/lazygit/config.yml\n' "${HOME}"
}

backup_root() {
  printf '%s/.config/better-git-aliases/backups\n' "${HOME}"
}

timestamp() {
  date '+%Y%m%d-%H%M%S'
}

path_has_dir() {
  local dir="$1" item old_ifs
  old_ifs="${IFS:- }"
  IFS=':'
  for item in $PATH; do
    [ "$item" = "$dir" ] && IFS="$old_ifs" && return 0
  done
  IFS="$old_ifs"
  return 1
}

shell_rc_path() {
  local shell_name
  shell_name="$(basename "${SHELL:-bash}")"
  case "$shell_name" in
    zsh) printf '%s/.zshrc\n' "$HOME" ;;
    bash|*) printf '%s/.bashrc\n' "$HOME" ;;
  esac
}

shell_rc_mentions_helper() {
  local rc helper
  rc="$(shell_rc_path)"
  helper="$(shell_helper_path)"
  [ -f "$rc" ] || return 1
  grep -Fq "$helper" "$rc"
}

die() {
  printf 'bga: %s\n' "$*" >&2
  exit 1
}

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null
}

repo_name() {
  basename "$(repo_root)"
}

sanitize_name() {
  printf '%s' "$1" | tr '/[:space:]' '--' | tr -cd '[:alnum:]._-' | sed 's/--*/-/g; s/^-//; s/-$//'
}

current_branch() {
  git branch --show-current 2>/dev/null || true
}

default_base_branch() {
  if git show-ref --verify --quiet refs/heads/main; then
    printf 'main\n'
  elif git show-ref --verify --quiet refs/heads/master; then
    printf 'master\n'
  else
    git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##' || printf 'main\n'
  fi
}

worktree_root() {
  local root name parent
  root="$(repo_root)"
  name="$(basename "$root")"
  parent="$(dirname "$root")"
  printf '%s/.worktrees/%s\n' "$parent" "$name"
}

ensure_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repository"
}

require_clean_or_confirm() {
  if ! git diff --quiet || ! git diff --cached --quiet; then
    printf 'warning: working tree has uncommitted changes\n' >&2
  fi
}

fzf_or_first() {
  local prompt="${1:-select> }"
  if has fzf; then
    fzf --height=80% --layout=reverse --border --prompt="$prompt"
  else
    head -n 1
  fi
}

list_branches() {
  git for-each-ref \
    --sort=-committerdate \
    --format='%(refname:short)|%(committerdate:relative)|%(authorname)|%(subject)' \
    refs/heads refs/remotes
}

branch_picker() {
  if has fzf; then
    list_branches | fzf \
      --delimiter='|' \
      --with-nth=1,2,3,4 \
      --preview-window='right,65%,border-left' \
      --height=85% \
      --layout=reverse \
      --border \
      --prompt='branch> ' \
      --header='branch | updated | author | subject' \
      --preview '
        branch=$(printf "%s" {} | cut -d"|" -f1)
        branch=${branch#origin/}
        git log --color=always --decorate --stat -n 12 "$branch"
      ' \
      | cut -d'|' -f1
  else
    list_branches | column -t -s '|' | fzf_or_first "branch> " | awk '{print $1}'
  fi
}

list_worktrees() {
  git worktree list --porcelain | awk '
    /^worktree / { path=$2 }
    /^branch / { branch=$2; sub("refs/heads/", "", branch) }
    /^HEAD / && branch == "" { branch="detached" }
    /^$/ {
      if (path != "") print path "|" branch
      path=""
      branch=""
    }'
}

current_worktree_path() {
  git rev-parse --path-format=absolute --show-toplevel 2>/dev/null
}

branch_worktrees() {
  local branch="$1"
  list_worktrees | awk -F'|' -v branch="$branch" '$2 == branch { print $1 "|" $2 }'
}

branch_is_merged_into() {
  local branch="$1" base="$2"
  git show-ref --verify --quiet "refs/heads/${branch}" || return 1
  git show-ref --verify --quiet "refs/heads/${base}" || return 1
  git merge-base --is-ancestor "refs/heads/${branch}" "refs/heads/${base}"
}

managed_worktree_path() {
  local path="$1"
  case "$path" in
    "$(worktree_root)"/*) return 0 ;;
    *) return 1 ;;
  esac
}

repo_is_dirty() {
  local path="$1"
  (
    cd "$path" || exit 1
    ! git diff --quiet || ! git diff --cached --quiet
  )
}

branch_upstream() {
  local branch="$1"
  git rev-parse --abbrev-ref --symbolic-full-name "${branch}@{upstream}" 2>/dev/null || true
}

branch_ahead_behind() {
  local branch="$1" upstream
  upstream="$(branch_upstream "$branch")"
  [ -n "$upstream" ] || return 1
  git rev-list --left-right --count "${branch}...${upstream}" 2>/dev/null
}

parse_ahead_behind() {
  local counts="$1"
  local ahead behind
  IFS=$'\t' read -r ahead behind <<EOF
$counts
EOF
  printf '%s %s\n' "${ahead:-0}" "${behind:-0}"
}

print_dashboard_attention() {
  local current_path branch path found=0 counts parsed ahead behind
  current_path="$(current_worktree_path)"
  printf 'attention:\n'

  if repo_is_dirty "$current_path"; then
    printf '  - current worktree has uncommitted changes\n'
    found=1
  fi

  branch="$(current_branch)"
  if [ -n "$branch" ]; then
    counts="$(branch_ahead_behind "$branch" || true)"
    if [ -n "$counts" ]; then
      parsed="$(parse_ahead_behind "$counts")"
      ahead="${parsed%% *}"
      behind="${parsed##* }"
      if [ "${ahead:-0}" -gt 0 ] || [ "${behind:-0}" -gt 0 ]; then
        printf '  - current branch %s is ahead %s / behind %s vs upstream\n' "$branch" "$ahead" "$behind"
        found=1
      fi
    else
      printf '  - current branch %s has no upstream\n' "$branch"
      found=1
    fi
  fi

  while IFS='|' read -r path branch; do
    [ -n "$path" ] || continue
    [ "$path" = "$current_path" ] && continue
    if repo_is_dirty "$path"; then
      printf '  - dirty worktree: %s (%s)\n' "$path" "$branch"
      found=1
    fi
  done < <(list_worktrees)

  while IFS='|' read -r path branch reason; do
    case "$path" in
      No\ stale\ managed\ worktrees\ found.) break ;;
    esac
    [ -n "$path" ] || continue
    printf '  - stale worktree: %s (%s)\n' "$path" "$branch"
    found=1
  done < <(cmd_worktree_stale "$(default_base_branch)")

  [ "$found" -eq 1 ] || printf '  - nothing urgent\n'
}

print_dashboard_worktrees() {
  local current_path path branch marker dirty
  current_path="$(current_worktree_path)"
  printf 'worktrees:\n'
  while IFS='|' read -r path branch; do
    [ -n "$path" ] || continue
    marker=' '
    [ "$path" = "$current_path" ] && marker='*'
    dirty='clean'
    if repo_is_dirty "$path"; then
      dirty='dirty'
    fi
    printf '  %s %s | %s | %s\n' "$marker" "$branch" "$dirty" "$path"
  done < <(list_worktrees)
}

print_dashboard_recent_branches() {
  local branch when author subject upstream counts parsed ahead behind line_count=0
  printf 'recent branches:\n'
  while IFS='|' read -r branch when author subject; do
    [ -n "$branch" ] || continue
    upstream="$(branch_upstream "${branch#origin/}")"
    if [ -n "$upstream" ]; then
      counts="$(branch_ahead_behind "${branch#origin/}" || true)"
      parsed="$(parse_ahead_behind "$counts")"
      ahead="${parsed%% *}"
      behind="${parsed##* }"
      printf '  %s | %s | ahead %s / behind %s | %s\n' "$branch" "$when" "${ahead:-0}" "${behind:-0}" "$subject"
    else
      printf '  %s | %s | no upstream | %s\n' "$branch" "$when" "$subject"
    fi
    line_count=$((line_count + 1))
    [ "$line_count" -ge 8 ] && break
  done < <(list_branches)
}

worktree_picker() {
  if has fzf; then
    list_worktrees | fzf \
      --delimiter='|' \
      --with-nth=2,1 \
      --preview-window='right,65%,border-left' \
      --height=85% \
      --layout=reverse \
      --border \
      --prompt='worktree> ' \
      --header='branch | path' \
      --preview '
        path=$(printf "%s" {} | cut -d"|" -f1)
        if [ -d "$path" ]; then
          cd "$path" || exit 1
          printf "Path: %s\n\n" "$path"
          git status -sb
          printf "\nRecent commits:\n"
          git log --oneline --decorate -n 10
          printf "\nFiles:\n"
          find . -maxdepth 2 -type f | sed "s#^\./##" | sort | head -n 40
        fi
      ' \
      | cut -d'|' -f1
  else
    list_worktrees | column -t -s '|' | fzf_or_first "worktree> " | awk '{print $1}'
  fi
}

open_lazygit() {
  local target="${1:-.}"
  has lazygit || die "lazygit is not installed"
  (cd "$target" && lazygit)
}

open_ai_cli() {
  local tool="$1"
  local target="${2:-.}"
  has "$tool" || die "$tool is not installed"
  (cd "$target" && "$tool")
}

open_url() {
  local url="$1"
  if has xdg-open; then
    xdg-open "$url" >/dev/null 2>&1 &
  elif has open; then
    open "$url" >/dev/null 2>&1 &
  else
    die "no supported URL opener found; print the URL and open it manually"
  fi
}

github_https_remote_url() {
  local remote="${1:-origin}" url host path
  url="$(git remote get-url "$remote" 2>/dev/null || true)"
  [ -n "$url" ] || die "git remote '$remote' not found"
  case "$url" in
    git@github.com:*)
      path="${url#git@github.com:}"
      path="${path%.git}"
      printf 'https://github.com/%s\n' "$path"
      ;;
    https://github.com/*)
      printf '%s\n' "${url%.git}"
      ;;
    ssh://git@github.com/*)
      path="${url#ssh://git@github.com/}"
      path="${path%.git}"
      printf 'https://github.com/%s\n' "$path"
      ;;
    *)
      die "remote '$remote' is not a supported GitHub URL: $url"
      ;;
  esac
}

tmux_attach_or_switch() {
  local session="$1"
  if [ -n "${TMUX:-}" ]; then
    exec tmux switch-client -t "$session"
  fi
  exec tmux attach -t "$session"
}

preferred_ai_tool() {
  if has codex; then
    printf 'codex\n'
  elif has cline; then
    printf 'cline\n'
  else
    return 1
  fi
}

cockpit_layout_exists() {
  case "$1" in
    solo|review|ai-pair|multi-feature) return 0 ;;
    *) return 1 ;;
  esac
}

cockpit_session_name() {
  local target="$1" layout="$2"
  local repo target_name
  repo="$(sanitize_name "$(repo_name)")"
  target_name="$(sanitize_name "$(basename "$target")")"
  printf 'bga-%s-%s-%s\n' "$repo" "$target_name" "$layout"
}

create_tmux_window() {
  local session="$1" target="$2" name="$3" command="$4"
  tmux new-window -t "$session" -c "$target" -n "$name"
  [ -n "$command" ] && tmux send-keys -t "$session:$name" "$command" C-m
}

configure_tmux_layout() {
  local session="$1" target="$2" layout="$3"
  local ai_tool=""
  ai_tool="$(preferred_ai_tool || true)"

  case "$layout" in
    solo)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      if [ -n "$ai_tool" ]; then
        create_tmux_window "$session" "$target" "$ai_tool" "$ai_tool"
      fi
      ;;
    review)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      create_tmux_window "$session" "$target" log "git log --graph --decorate --oneline -n 40"
      create_tmux_window "$session" "$target" status "git status -sb && printf '\\nRecent branches:\\n' && git branch --sort=-committerdate | head -n 12"
      ;;
    ai-pair)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      if [ -n "$ai_tool" ]; then
        create_tmux_window "$session" "$target" "$ai_tool" "$ai_tool"
      fi
      create_tmux_window "$session" "$target" notes "printf 'Branch: '; git branch --show-current; printf '\\nNext actions:\\n- inspect diff\\n- ask AI for help\\n- apply and test changes\\n'"
      ;;
    multi-feature)
      create_tmux_window "$session" "$target" git "$(has lazygit && printf 'lazygit' || printf 'git status -sb')"
      create_tmux_window "$session" "$target" worktrees "git worktree list && printf '\\nRecent branches:\\n' && git branch --sort=-committerdate | head -n 20"
      create_tmux_window "$session" "$target" status "watch -n 5 'git status -sb; printf \"\\n\"; git branch --show-current'" 
      if [ -n "$ai_tool" ]; then
        create_tmux_window "$session" "$target" "$ai_tool" "$ai_tool"
      fi
      ;;
  esac
}

open_tmux_workspace() {
  local target="${1:-.}"
  local layout="${2:-solo}"
  local session
  has tmux || die "tmux is not installed"
  cockpit_layout_exists "$layout" || die "unknown cockpit layout: $layout"
  session="$(cockpit_session_name "$target" "$layout")"

  if tmux has-session -t "$session" 2>/dev/null; then
    tmux_attach_or_switch "$session"
  fi

  tmux new-session -d -s "$session" -c "$target" -n shell
  tmux send-keys -t "$session:shell" 'clear' C-m
  configure_tmux_layout "$session" "$target" "$layout"
  tmux select-window -t "$session:shell"
  tmux_attach_or_switch "$session"
}

cmd_help() {
  cat <<'EOF'
better-git-aliases

Core:
  bga help                      Show this help
  bga doctor                    Check environment and dependencies
  bga bootstrap [brew|apt]      Install recommended dependencies
  bga lazygit-config <subcmd>   Manage curated lazygit config
  bga menu                      Show interactive workflow menu
  bga dashboard                 Show repo + worktree overview
  bga sync                      Fetch and rebase current branch
  bga recent                    Pick and checkout a recent branch
  bga commits                   Browse commits with preview
  bga prune-merged              Delete merged local branches safely

Feature workflow:
  bga feature start NAME [BASE] Create branch + worktree
  bga feature ship              Status checklist before push/merge
  bga feature finish [BRANCH] [--base BASE]
                                Clean up merged feature branch + worktree

Worktree workflow:
  bga worktree list             List worktrees
  bga worktree stale [BASE]     List merged worktrees that are good cleanup candidates
  bga worktree clean [BASE] [--apply]
                                Remove stale managed worktrees
  bga worktree add NAME [BASE]  Create a new worktree for a branch
  bga worktree path [QUERY]     Print selected worktree path
  bga worktree remove [QUERY]   Remove a worktree
  bga worktree tmux [QUERY] [--layout LAYOUT]
                                Open selected worktree in tmux
  bga worktree lazygit [QUERY]  Open selected worktree in lazygit

Tool integrations:
  bga lazygit [QUERY]           Open current or chosen worktree in lazygit
  bga codex [QUERY]             Run codex in current or chosen worktree
  bga cline [QUERY]             Run cline in current or chosen worktree
  bga github repo [--open]      Print or open the GitHub repo URL
  bga github status [BASE]      Show branch publish and review context
  bga github publish            Push current branch and set upstream if needed
  bga github compare [BASE] [--open]
                                Print or open the compare URL for current branch
  bga github pr [BASE] [--open] Print or open the new PR URL for current branch
  bga cockpit [QUERY] [--layout LAYOUT]
                                Open tmux cockpit for a worktree
  bga cockpit list-layouts      Show available cockpit layouts

Shell integration:
  bga init bash
  bga init zsh

Recommended git aliases after install:
  git doctor
  git bootstrap
  git lazygit-config
  git menu
  git dash
  git sync
  git recent
  git wt / git wta / git wtrm / git wttmux
  git feature
  git lg / git codex / git cline / git cockpit
EOF
}

cmd_doctor() {
  local missing=0
  printf 'better-git-aliases doctor\n\n'
  printf 'core:\n'
  for tool in git bash; do
    if has "$tool"; then
      printf '  [ok]   %s -> %s\n' "$tool" "$(command -v "$tool")"
    else
      printf '  [miss] %s\n' "$tool"
      missing=1
    fi
  done

  printf '\nrecommended:\n'
  for tool in fzf lazygit tmux delta codex cline; do
    if has "$tool"; then
      printf '  [ok]   %s -> %s\n' "$tool" "$(command -v "$tool")"
    else
      printf '  [skip] %s\n' "$tool"
    fi
  done

  printf '\ngit include:\n'
  if git config --global --get-all include.path 2>/dev/null | grep -Fqx "$(config_home)/gitconfig.include"; then
    printf '  [ok]   %s\n' "$(config_home)/gitconfig.include"
  else
    printf '  [miss] %s\n' "$(config_home)/gitconfig.include"
  fi

  printf '\npath:\n'
  if path_has_dir "${HOME}/.local/bin"; then
    printf '  [ok]   ~/.local/bin is in PATH\n'
  else
    printf '  [miss] ~/.local/bin is not in PATH\n'
    printf '  [hint] add this to %s:\n' "$(shell_rc_path)"
    printf '         export PATH="$HOME/.local/bin:$PATH"\n'
  fi

  printf '\nshell helpers:\n'
  if [ -n "${BGA_SHELL_LOADED:-}" ]; then
    printf '  [ok]   current shell already sourced bga.sh\n'
  elif [ -f "$(shell_helper_path)" ]; then
    printf '  [info] source %s to enable gwt/gcodex/gcline/gcockpit\n' "$(shell_helper_path)"
    if shell_rc_mentions_helper; then
      printf '  [ok]   shell rc references the helper file\n'
    else
      printf '  [hint] add this to %s:\n' "$(shell_rc_path)"
      printf '         source "%s"\n' "$(shell_helper_path)"
    fi
  else
    printf '  [miss] shell helper file not found\n'
  fi

  printf '\nlazygit config:\n'
  if [ -f "${HOME}/.config/lazygit/config.yml" ]; then
    printf '  [ok]   %s\n' "${HOME}/.config/lazygit/config.yml"
  else
    printf '  [info] run: bga lazygit-config install\n'
  fi

  printf '\ninteractive features:\n'
  if has fzf; then
    printf '  [ok]   fzf pickers are available\n'
  else
    printf '  [skip] fzf not found; menu/recent/worktree pickers fall back to simpler behavior\n'
  fi
  if has tmux; then
    printf '  [ok]   tmux cockpit is available\n'
  else
    printf '  [skip] tmux not found; cockpit layouts are unavailable\n'
  fi
  if has lazygit; then
    printf '  [ok]   lazygit integration is available\n'
  else
    printf '  [skip] lazygit not found; git status fallback will be used in tmux/git flows\n'
  fi

  printf '\nembedded assets:\n'
  if managed_lazygit_template_path >/dev/null 2>&1; then
    printf '  [ok]   %s\n' "$(managed_lazygit_template_path)"
  else
    printf '  [miss] lazygit template not found\n'
  fi

  printf '\nnext steps:\n'
  if ! has fzf || ! has tmux || ! has lazygit || ! path_has_dir "${HOME}/.local/bin"; then
    printf '  - run: git bootstrap\n'
  fi
  if [ ! -f "${HOME}/.config/lazygit/config.yml" ]; then
    printf '  - run: git lazygit-config install\n'
  fi
  if [ -f "$(shell_helper_path)" ] && [ -z "${BGA_SHELL_LOADED:-}" ]; then
    printf '  - add shell helper to %s and reload your shell\n' "$(shell_rc_path)"
  fi

  [ "$missing" -eq 0 ] || return 1
}

cmd_bootstrap() {
  local manager="${1:-auto}"
  if [ "$manager" = "auto" ]; then
    if has brew; then
      manager="brew"
    elif has apt-get; then
      manager="apt"
    else
      die "no supported package manager found; use brew or apt explicitly"
    fi
  fi

  case "$manager" in
    brew)
      has brew || die "brew is not installed"
      brew install git fzf lazygit tmux git-delta
      ;;
    apt)
      has apt-get || die "apt-get is not installed"
      sudo apt-get update
      sudo apt-get install -y git fzf tmux git-delta
      if ! has lazygit; then
        printf 'lazygit is not in standard apt repos on many systems; install it separately if needed.\n'
      fi
      ;;
    *)
      die "supported package managers: brew, apt"
      ;;
  esac
}

cmd_lazygit_config() {
  local action="${1:-install}"
  local target_dir="${HOME}/.config/lazygit"
  local target_file
  local source_file
  source_file="$(managed_lazygit_template_path)" || die "lazygit template not found; reinstall better-git-aliases"
  target_file="$(managed_lazygit_config_path)"
  case "$action" in
    install)
      mkdir -p "$target_dir"
      install -m 0644 "$source_file" "$target_file"
      printf 'Installed lazygit config: %s\n' "$target_file"
      ;;
    path)
      printf '%s\n' "$target_file"
      ;;
    diff)
      if [ ! -f "$target_file" ]; then
        die "lazygit config not found at $target_file"
      fi
      if command -v diff >/dev/null 2>&1; then
        diff -u "$target_file" "$source_file" || true
      else
        die "diff command is not available"
      fi
      ;;
    backup)
      if [ ! -f "$target_file" ]; then
        die "lazygit config not found at $target_file"
      fi
      local backup_dir backup_file
      backup_dir="$(backup_root)/lazygit"
      mkdir -p "$backup_dir"
      backup_file="${backup_dir}/config.$(timestamp).yml"
      cp "$target_file" "$backup_file"
      printf 'Backed up lazygit config to: %s\n' "$backup_file"
      ;;
    merge-hint)
      cat <<EOF
Managed template:
  $source_file

Current lazygit config:
  $target_file

Recommended merge flow:
  1. Back up your current config:
     bga lazygit-config backup
  2. Review differences:
     bga lazygit-config diff
  3. Keep your personal preferences and copy only the workflow-specific pieces:
     - customCommands
     - git.paging
     - keybinding overrides you actually want
  4. Re-install the managed version only if you want a full reset:
     bga lazygit-config install

Practical rule:
  Treat the bundled config as a reference baseline, not something you must overwrite every time.
EOF
      ;;
    *)
      die "usage: bga lazygit-config <install|path|diff|backup|merge-hint>"
      ;;
  esac
}

cmd_dashboard() {
  ensure_repo
  local root branch
  root="$(repo_root)"
  branch="$(current_branch)"
  printf 'repo:      %s\n' "$root"
  printf 'branch:    %s\n' "${branch:-detached}"
  printf 'base:      %s\n' "$(default_base_branch)"
  printf 'status:\n'
  git status -sb
  printf '\n'
  print_dashboard_attention
  printf '\n'
  print_dashboard_worktrees
  printf '\n'
  print_dashboard_recent_branches
}

cmd_sync() {
  ensure_repo
  local branch upstream
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  git fetch --all --prune
  upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" 2>/dev/null || true)"
  if [ -n "$upstream" ]; then
    git pull --rebase --autostash
  else
    printf 'No upstream set for %s. Fetched remotes only.\n' "$branch"
  fi
}

cmd_recent() {
  ensure_repo
  local selected
  selected="$(branch_picker)"
  [ -n "${selected:-}" ] || exit 0
  git checkout "${selected#origin/}"
}

cmd_commits() {
  ensure_repo
  if has fzf; then
    git log --graph --color=always \
      --pretty=format:'%C(auto)%h%d %s %C(black)%C(bold)%cr %C(auto)<%an>' \
      --abbrev-commit \
      | fzf --ansi --no-sort --reverse --tiebreak=index \
          --height=85% \
          --border \
          --preview-window='right,65%,border-left' \
          --preview 'echo {} | grep -o "[a-f0-9]\{7,\}" | head -n1 | xargs -r git show --color=always --stat --patch' \
          --prompt='commit> '
  else
    git log --oneline --decorate -n 30
  fi
}

cmd_prune_merged() {
  ensure_repo
  local protected current
  current="$(current_branch)"
  protected="main|master|develop|dev|${current}"
  git branch --merged \
    | sed 's/^[* ]*//' \
    | grep -Ev "^(${protected})$" \
    | awk 'NF' \
    | while read -r branch; do
        git branch -d "$branch"
      done
}

cmd_feature_start() {
  ensure_repo
  local name base branch target_root target_path
  name="${1:-}"
  base="${2:-$(default_base_branch)}"
  [ -n "$name" ] || die "usage: bga feature start <name> [base]"
  branch="feature/${name}"
  target_root="$(worktree_root)"
  target_path="${target_root}/${branch//\//-}"

  mkdir -p "$target_root"
  git fetch --all --prune

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    git worktree add "$target_path" "$branch" >/dev/null
  else
    git worktree add -b "$branch" "$target_path" "$base" >/dev/null
  fi

  printf '%s\n' "$target_path"
}

cmd_feature_ship() {
  ensure_repo
  local branch
  branch="$(current_branch)"
  printf 'Branch: %s\n' "${branch:-detached}"
  printf '\nStatus:\n'
  git status -sb
  printf '\nAhead/behind:\n'
  git rev-list --left-right --count HEAD..."@{upstream}" 2>/dev/null || printf 'no upstream\n'
  printf '\nRecent commits:\n'
  git log --oneline -n 5
}

cmd_feature_finish() {
  ensure_repo
  local branch="" base="" current_path path current_branch_name deleted_branch=0
  current_branch_name="$(current_branch)"
  current_path="$(current_worktree_path)"

  while [ $# -gt 0 ]; do
    case "$1" in
      --base)
        shift
        [ -n "${1:-}" ] || die "usage: bga feature finish [BRANCH] [--base BASE]"
        base="$1"
        ;;
      *)
        branch="$1"
        ;;
    esac
    shift || true
  done

  [ -n "$branch" ] || branch="$current_branch_name"
  [ -n "$branch" ] || die "usage: bga feature finish [BRANCH] [--base BASE]"
  [ -n "$base" ] || base="$(default_base_branch)"

  branch_is_merged_into "$branch" "$base" || die "branch '$branch' is not merged into '$base'"

  printf 'Finishing branch: %s\n' "$branch"
  printf 'Base branch:      %s\n' "$base"

  while IFS='|' read -r path _; do
    [ -n "$path" ] || continue
    if [ "$path" = "$current_path" ]; then
      printf 'Skip current worktree: %s\n' "$path"
      continue
    fi
    if ! managed_worktree_path "$path"; then
      printf 'Skip unmanaged worktree: %s\n' "$path"
      continue
    fi
    git worktree remove "$path"
    printf 'Removed worktree: %s\n' "$path"
  done < <(branch_worktrees "$branch")

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    if git branch -d "$branch" >/dev/null 2>&1; then
      printf 'Deleted local branch: %s\n' "$branch"
      deleted_branch=1
    else
      printf 'Skipped deleting branch (still checked out in a worktree): %s\n' "$branch"
    fi
  fi

  [ "$deleted_branch" -eq 1 ] || true
}

cmd_worktree_list() {
  ensure_repo
  list_worktrees | column -t -s '|'
}

cmd_worktree_stale() {
  ensure_repo
  local base="${1:-$(default_base_branch)}"
  local current_path branch path found=0
  current_path="$(current_worktree_path)"

  while IFS='|' read -r path branch; do
    [ -n "$path" ] || continue
    [ -n "$branch" ] || continue
    [ "$branch" = "detached" ] && continue
    [ "$branch" = "$base" ] && continue
    [ "$path" = "$current_path" ] && continue
    managed_worktree_path "$path" || continue
    if branch_is_merged_into "$branch" "$base"; then
      printf '%s|%s|merged-into-%s\n' "$path" "$branch" "$base"
      found=1
    fi
  done < <(list_worktrees)

  [ "$found" -eq 1 ] || printf 'No stale managed worktrees found.\n'
}

cmd_worktree_clean() {
  ensure_repo
  local apply=0 base="" path branch reason
  while [ $# -gt 0 ]; do
    case "$1" in
      --apply)
        apply=1
        ;;
      *)
        base="$1"
        ;;
    esac
    shift || true
  done
  [ -n "$base" ] || base="$(default_base_branch)"

  if [ "$apply" -eq 0 ]; then
    printf 'Dry run. Use --apply to remove these stale managed worktrees.\n\n'
  fi

  while IFS='|' read -r path branch reason; do
    case "$path" in
      No\ stale\ managed\ worktrees\ found.) printf '%s\n' "$path"; return 0 ;;
    esac
    [ -n "$path" ] || continue
    if [ "$apply" -eq 1 ]; then
      git worktree remove "$path"
      printf 'Removed: %s (%s)\n' "$path" "$branch"
    else
      printf 'Would remove: %s (%s, %s)\n' "$path" "$branch" "$reason"
    fi
  done < <(cmd_worktree_stale "$base")
}

resolve_worktree_path() {
  ensure_repo
  local query="${1:-}"
  if [ -n "$query" ] && [ -d "$query" ]; then
    printf '%s\n' "$query"
    return 0
  fi

  if [ -n "$query" ]; then
    local match
    match="$(list_worktrees | grep -E "${query}" | head -n 1 | cut -d'|' -f1 || true)"
    [ -n "$match" ] && printf '%s\n' "$match" && return 0
  fi

  worktree_picker
}

cmd_worktree_add() {
  ensure_repo
  local name="${1:-}" base="${2:-$(default_base_branch)}" branch target_root target_path
  [ -n "$name" ] || die "usage: bga worktree add <branch-or-name> [base]"
  branch="$name"
  target_root="$(worktree_root)"
  target_path="${target_root}/${branch//\//-}"
  mkdir -p "$target_root"
  git fetch --all --prune

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    git worktree add "$target_path" "$branch" >/dev/null
  else
    git worktree add -b "$branch" "$target_path" "$base" >/dev/null
  fi

  printf '%s\n' "$target_path"
}

cmd_worktree_path() {
  local selected
  selected="$(resolve_worktree_path "${1:-}")"
  [ -n "${selected:-}" ] || exit 0
  printf '%s\n' "$selected"
}

cmd_worktree_remove() {
  ensure_repo
  local target
  target="$(resolve_worktree_path "${1:-}")"
  [ -n "${target:-}" ] || exit 0
  git worktree remove "$target"
}

cmd_worktree_tmux() {
  local target_query="" target layout="solo"
  while [ $# -gt 0 ]; do
    case "$1" in
      --layout)
        shift
        [ -n "${1:-}" ] || die "usage: bga worktree tmux [QUERY] [--layout LAYOUT]"
        layout="$1"
        ;;
      *)
        target_query="$1"
        ;;
    esac
    shift || true
  done
  target="$(resolve_worktree_path "$target_query")"
  [ -n "${target:-}" ] || exit 0
  open_tmux_workspace "$target" "$layout"
}

cmd_worktree_lazygit() {
  local target
  target="$(resolve_worktree_path "${1:-}")"
  [ -n "${target:-}" ] || exit 0
  open_lazygit "$target"
}

cmd_lazygit() {
  if [ $# -gt 0 ]; then
    cmd_worktree_lazygit "$1"
  else
    open_lazygit "."
  fi
}

cmd_codex() {
  local target="."
  [ $# -gt 0 ] && target="$(resolve_worktree_path "$1")"
  open_ai_cli codex "$target"
}

cmd_cline() {
  local target="."
  [ $# -gt 0 ] && target="$(resolve_worktree_path "$1")"
  open_ai_cli cline "$target"
}

cmd_github_repo() {
  ensure_repo
  local open_flag=0 url
  if [ "${1:-}" = "--open" ]; then
    open_flag=1
  fi
  url="$(github_https_remote_url origin)"
  if [ "$open_flag" -eq 1 ]; then
    open_url "$url"
  else
    printf '%s\n' "$url"
  fi
}

cmd_github_status() {
  ensure_repo
  local base="" branch repo_url compare_url pr_url upstream counts parsed ahead behind
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  [ -n "${1:-}" ] && base="$1" || base="$(default_base_branch)"
  repo_url="$(github_https_remote_url origin)"
  compare_url="${repo_url}/compare/${base}...${branch}?expand=1"
  pr_url="${repo_url}/compare/${base}...${branch}?expand=1&template=pull_request_template.md"
  upstream="$(branch_upstream "$branch")"

  printf 'repo:     %s\n' "$repo_url"
  printf 'branch:   %s\n' "$branch"
  printf 'base:     %s\n' "$base"
  if [ -n "$upstream" ]; then
    counts="$(branch_ahead_behind "$branch" || true)"
    parsed="$(parse_ahead_behind "$counts")"
    ahead="${parsed%% *}"
    behind="${parsed##* }"
    printf 'upstream: %s\n' "$upstream"
    printf 'publish:  yes (ahead %s / behind %s)\n' "${ahead:-0}" "${behind:-0}"
  else
    printf 'upstream: none\n'
    printf 'publish:  no\n'
  fi
  printf 'compare:  %s\n' "$compare_url"
  printf 'pr:       %s\n' "$pr_url"
}

cmd_github_publish() {
  ensure_repo
  local branch upstream
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  upstream="$(branch_upstream "$branch")"
  if [ -n "$upstream" ]; then
    git push
  else
    git push -u origin "$branch"
  fi
}

cmd_github_compare() {
  ensure_repo
  local base="" open_flag=0 branch url repo_url
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  while [ $# -gt 0 ]; do
    case "$1" in
      --open) open_flag=1 ;;
      *) base="$1" ;;
    esac
    shift || true
  done
  [ -n "$base" ] || base="$(default_base_branch)"
  repo_url="$(github_https_remote_url origin)"
  url="${repo_url}/compare/${base}...${branch}?expand=1"
  if [ "$open_flag" -eq 1 ]; then
    open_url "$url"
  else
    printf '%s\n' "$url"
  fi
}

cmd_github_pr() {
  ensure_repo
  local base="" open_flag=0 branch url repo_url
  branch="$(current_branch)"
  [ -n "$branch" ] || die "detached HEAD; checkout a branch first"
  while [ $# -gt 0 ]; do
    case "$1" in
      --open) open_flag=1 ;;
      *) base="$1" ;;
    esac
    shift || true
  done
  [ -n "$base" ] || base="$(default_base_branch)"
  repo_url="$(github_https_remote_url origin)"
  url="${repo_url}/compare/${base}...${branch}?expand=1&template=pull_request_template.md"
  if [ "$open_flag" -eq 1 ]; then
    open_url "$url"
  else
    printf '%s\n' "$url"
  fi
}

cmd_cockpit() {
  local target="." layout="solo"
  if [ "${1:-}" = "list-layouts" ]; then
    printf 'solo\nreview\nai-pair\nmulti-feature\n'
    return 0
  fi
  while [ $# -gt 0 ]; do
    case "$1" in
      --layout)
        shift
        [ -n "${1:-}" ] || die "usage: bga cockpit [QUERY] [--layout LAYOUT]"
        layout="$1"
        ;;
      *)
        target="$(resolve_worktree_path "$1")"
        ;;
    esac
    shift || true
  done
  open_tmux_workspace "$target" "$layout"
}

cmd_init() {
  local shell_name="${1:-bash}"
  local helper
  helper="$(shell_helper_path)"
  case "$shell_name" in
    bash|zsh)
      cat <<EOF
source "${helper}"
EOF
      ;;
    *)
      die "supported shells: bash, zsh"
      ;;
  esac
}

prompt_input() {
  local label="$1" value
  printf '%s' "$label"
  read -r value
  printf '%s\n' "$value"
}

menu_prompt_feature_start() {
  local name base
  name="$(prompt_input 'feature name: ')"
  [ -n "$name" ] || return 0
  base="$(prompt_input "base branch [$(default_base_branch)]: ")"
  if [ -n "$base" ]; then
    cmd_feature_start "$name" "$base"
  else
    cmd_feature_start "$name"
  fi
}

menu_prompt_resume_feature() {
  local target action layout
  target="$(resolve_worktree_path "${1:-}")"
  [ -n "$target" ] || return 0
  printf 'resume action:\n'
  printf '  1. jump path only\n'
  printf '  2. open lazygit\n'
  printf '  3. open tmux cockpit\n'
  action="$(prompt_input 'choose [1/2/3]: ')"
  case "$action" in
    1|"")
      printf '%s\n' "$target"
      ;;
    2)
      open_lazygit "$target"
      ;;
    3)
      layout="$(prompt_input 'layout [solo]: ')"
      open_tmux_workspace "$target" "${layout:-solo}"
      ;;
    *)
      die "invalid choice: $action"
      ;;
  esac
}

menu_review_and_commit() {
  if has lazygit; then
    open_lazygit "."
  else
    printf 'lazygit is not installed. Showing git status instead.\n\n'
    git status -sb
    printf '\nTip: install lazygit for the best review workflow.\n'
  fi
}

menu_cleanup_merged_work() {
  local apply
  printf 'cleanup preview:\n\n'
  cmd_worktree_clean
  printf '\n'
  cmd_prune_merged
  printf '\n'
  apply="$(prompt_input 'apply stale worktree cleanup now? [y/N]: ')"
  case "$apply" in
    y|Y|yes|YES)
      cmd_worktree_clean --apply
      ;;
  esac
}

run_menu_action() {
  local label="$1"
  case "$label" in
    "Start a new feature") menu_prompt_feature_start ;;
    "Resume existing feature") menu_prompt_resume_feature ;;
    "Review and commit changes") menu_review_and_commit ;;
    "Clean up merged work") menu_cleanup_merged_work ;;
    "Show GitHub status for current branch") cmd_github_status ;;
    "Publish current branch to GitHub") cmd_github_publish ;;
    "Open GitHub compare for current branch") cmd_github_compare --open ;;
    "Open GitHub PR page for current branch") cmd_github_pr --open ;;
    "Doctor") cmd_doctor ;;
    "Bootstrap dependencies") cmd_bootstrap ;;
    "Install lazygit config") cmd_lazygit_config install ;;
    "Dashboard") cmd_dashboard ;;
    "Sync current branch") cmd_sync ;;
    "Checkout recent branch") cmd_recent ;;
    "Browse commits") cmd_commits ;;
    "Create feature worktree") menu_prompt_feature_start ;;
    "List worktrees") cmd_worktree_list ;;
    "Open worktree in lazygit") cmd_worktree_lazygit ;;
    "Open worktree cockpit (tmux)") cmd_worktree_tmux ;;
    "Prune merged branches") cmd_prune_merged ;;
    "Help") cmd_help ;;
  esac
}

menu_preview() {
  case "$1" in
    "Doctor")
      cat <<'EOF'
Check whether the local environment is ready.

Shows:
- required tools
- recommended tools
- git include installation
- shell helper status
EOF
      ;;
    "Open GitHub compare for current branch")
      cat <<'EOF'
Open the GitHub compare page for the current branch.

Useful before:
- creating a PR
- checking the final diff
- sharing a review URL
EOF
      ;;
    "Show GitHub status for current branch")
      cat <<'EOF'
Show publish/review context for the current branch.

Includes:
- repo URL
- branch and base
- upstream/publish state
- compare URL
- PR URL
EOF
      ;;
    "Publish current branch to GitHub")
      cat <<'EOF'
Push the current branch to origin.

Behavior:
- if the branch already has an upstream, run a normal push
- otherwise push with -u to set upstream tracking
EOF
      ;;
    "Open GitHub PR page for current branch")
      cat <<'EOF'
Open the GitHub new-PR page for the current branch.

Uses the current branch and the default base branch unless you specify another base manually in CLI usage.
EOF
      ;;
    "Start a new feature")
      cat <<'EOF'
Guided feature setup.

Prompts for:
- feature name
- optional base branch

Then creates a dedicated feature branch and matching worktree.
EOF
      ;;
    "Resume existing feature")
      cat <<'EOF'
Pick an existing worktree and continue working.

Options:
- print the path
- open lazygit
- open tmux cockpit
EOF
      ;;
    "Review and commit changes")
      cat <<'EOF'
Open the safest review flow before commit.

Behavior:
- opens lazygit if available
- otherwise falls back to git status with a hint
EOF
      ;;
    "Clean up merged work")
      cat <<'EOF'
Preview stale managed worktrees and merged branches.

Behavior:
- shows a dry-run cleanup
- lets you confirm managed worktree cleanup
- also prunes merged local branches
EOF
      ;;
    "Bootstrap dependencies")
      cat <<'EOF'
Install recommended dependencies.

Supported:
- brew
- apt

Use this on a fresh machine before relying on menu, fzf, tmux, or lazygit workflows.
EOF
      ;;
    "Install lazygit config")
      cat <<'EOF'
Install the curated lazygit config for this workflow.

Includes:
- cleaner UI defaults
- git pager via delta
- shortcuts for bga/tmux/codex/cline flows
EOF
      ;;
    "Dashboard")
      cat <<'EOF'
Repo summary for quick orientation.

Shows:
- current repo root
- current branch
- git status
- worktrees
- recent branches
EOF
      ;;
    "Sync current branch")
      cat <<'EOF'
Fetch remotes and rebase current branch if it has an upstream.

Good start-of-day command.
EOF
      ;;
    "Checkout recent branch")
      cat <<'EOF'
Open a fuzzy branch picker.

Preview:
- recent commits
- stats
- decorations
EOF
      ;;
    "Browse commits")
      cat <<'EOF'
Open commit history with patch preview.

Useful for:
- reviewing recent work
- copying commit hashes
- understanding branch history
EOF
      ;;
    "Create feature worktree")
      cat <<'EOF'
Create a new feature branch and matching worktree.

Pattern:
- branch: feature/<name>
- path: ../.worktrees/<repo>/feature-<name>
EOF
      ;;
    "List worktrees")
      cat <<'EOF'
Show all worktrees attached to the current repo.

Use this when juggling multiple features.
EOF
      ;;
    "Open worktree in lazygit")
      cat <<'EOF'
Select a worktree and launch lazygit inside it.

Best for:
- staging hunks
- reviewing diffs
- branch and stash inspection
EOF
      ;;
    "Open worktree cockpit (tmux)")
      cat <<'EOF'
Select a worktree and open a tmux session around it.

Typical windows:
- shell
- git/lazygit
- codex or cline

Layouts:
- solo
- review
- ai-pair
- multi-feature
EOF
      ;;
    "Prune merged branches")
      cat <<'EOF'
Delete merged local branches, excluding protected names.

Protected by default:
- main
- master
- develop
- dev
- current branch
EOF
      ;;
    "Help")
      cat <<'EOF'
Show the full command reference.
EOF
      ;;
  esac
}

cmd_menu() {
  local items selected
  items=$'Start a new feature\nResume existing feature\nReview and commit changes\nClean up merged work\nShow GitHub status for current branch\nPublish current branch to GitHub\nOpen GitHub compare for current branch\nOpen GitHub PR page for current branch\nDoctor\nBootstrap dependencies\nInstall lazygit config\nDashboard\nSync current branch\nCheckout recent branch\nBrowse commits\nCreate feature worktree\nList worktrees\nOpen worktree in lazygit\nOpen worktree cockpit (tmux)\nPrune merged branches\nHelp'
  if has fzf; then
    selected="$(printf '%s\n' "$items" | fzf \
      --height=80% \
      --layout=reverse \
      --border \
      --preview-window='right,55%,border-left,wrap' \
      --prompt='menu> ' \
      --header='better-git-aliases menu' \
      --preview "\"${BGA_BIN_DIR}/bga\" __menu-preview {}" )"
  else
    printf '%s\n' "$items"
    printf 'select exactly one label: '
    read -r selected
  fi
  [ -n "${selected:-}" ] || exit 0
  run_menu_action "$selected"
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    __menu-preview) menu_preview "${1:-}" ;;
    help|-h|--help) cmd_help ;;
    doctor) cmd_doctor ;;
    bootstrap) cmd_bootstrap "$@" ;;
    lazygit-config) cmd_lazygit_config "$@" ;;
    menu) cmd_menu ;;
    dashboard|dash) cmd_dashboard ;;
    sync) cmd_sync ;;
    recent) cmd_recent ;;
    commits) cmd_commits ;;
    prune-merged) cmd_prune_merged ;;
    feature)
      case "${1:-}" in
        start) shift; cmd_feature_start "$@" ;;
        ship) shift; cmd_feature_ship "$@" ;;
        finish) shift; cmd_feature_finish "$@" ;;
        *) die "usage: bga feature <start|ship> ..." ;;
      esac
      ;;
    worktree|wt)
      case "${1:-list}" in
        list) shift; cmd_worktree_list "$@" ;;
        stale) shift; cmd_worktree_stale "$@" ;;
        clean) shift; cmd_worktree_clean "$@" ;;
        add) shift; cmd_worktree_add "$@" ;;
        path) shift; cmd_worktree_path "$@" ;;
        remove|rm) shift; cmd_worktree_remove "$@" ;;
        tmux) shift; cmd_worktree_tmux "$@" ;;
        lazygit|lg) shift; cmd_worktree_lazygit "$@" ;;
        *) die "usage: bga worktree <list|stale|clean|add|path|remove|tmux|lazygit> ..." ;;
      esac
      ;;
    lazygit|lg) cmd_lazygit "$@" ;;
    codex) cmd_codex "$@" ;;
    cline) cmd_cline "$@" ;;
    github)
      case "${1:-}" in
        repo) shift; cmd_github_repo "$@" ;;
        status) shift; cmd_github_status "$@" ;;
        publish) shift; cmd_github_publish "$@" ;;
        compare) shift; cmd_github_compare "$@" ;;
        pr) shift; cmd_github_pr "$@" ;;
        *) die "usage: bga github <repo|status|publish|compare|pr> [--open]" ;;
      esac
      ;;
    cockpit) cmd_cockpit "$@" ;;
    init) cmd_init "$@" ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
